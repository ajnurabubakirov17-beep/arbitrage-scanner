async def send_notification(chat_id, opp, context):
    """Отправляет уведомление пользователю"""
    msg = f"""
🚀 <b>СПРЕД НАЙДЕН!</b>

💰 <b>{opp['coin']}/USDT</b>
📊 Спред: <b>{opp['spread']:.2f}%</b>

📈 <b>КУПИТЬ:</b> {opp['buy_exchange'].upper()} | ${opp['buy_price']:.6f}
📉 <b>ПРОДАТЬ:</b> {opp['sell_exchange'].upper()} | ${opp['sell_price']:.6f}

💸 <b>КОМИССИИ:</b>
• Биржевые: {opp['buy_fee']:.2f}% + {opp['sell_fee']:.2f}%
• Сетевая: <b>${opp['network_fee']:.2f}</b>
• Время перевода: <b>{opp['transfer_time']} мин</b>

✨ <b>РЕЗУЛЬТАТ:</b>
💰 Чистая прибыль: <b>${opp['net_profit']:.2f}</b>
📈 Доходность: <b>{opp['profit_percent']:.2f}%</b>
💵 Объем торгов: <b>${opp['volume']:,.0f}</b>
"""
    try:
        await context.bot.send_message(chat_id=chat_id, text=msg, parse_mode='HTML')
        logger.info(f"📨 Уведомление отправлено: {opp['coin']}")
    except Exception as e:
        logger.error(f"Ошибка отправки: {e}")

async def check_and_notify_users(context):
    """Проверяет данные и отправляет уведомления только активным пользователям"""
    global last_scan_data
    
    if not last_scan_data["prices"]:
        return
    
    for chat_id, user in USERS.items():
        if not user.get("active", False):
            continue
        
        opportunities = analyze_arbitrage(last_scan_data["prices"], user["settings"])
        
        for opp in opportunities[:5]:
            key = f"{opp['coin']}_{opp['buy_exchange']}_{opp['sell_exchange']}"
            now = time.time()
            
            if key in user["last_alerts"] and now - user["last_alerts"][key] < 300:
                continue
            
            user["last_alerts"][key] = now
            await send_notification(chat_id, opp, context)

async def button_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    chat_id = query.message.chat_id
    data = query.data
    
    if chat_id not in USERS:
        USERS[chat_id] = {"active": False, "settings": {"amount": 500, "min_spread": 0.3}, "last_alerts": {}}
    
    user = USERS[chat_id]
    
    # Запуск уведомлений
    if data == "start":
        user["active"] = True
        await query.edit_message_text(
            "✅ <b>УВЕДОМЛЕНИЯ ВКЛЮЧЕНЫ!</b>\n\nЯ буду присылать спреды только когда они появятся.\n\nЧтобы посмотреть спреды сейчас - нажмите 'ПОКАЗАТЬ СПРЕДЫ СЕЙЧАС'",
