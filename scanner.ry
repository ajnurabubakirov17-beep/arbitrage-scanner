# ========= БИРЖИ =========
async def init_exchanges():
    for name in EXCHANGES_LIST:
        try:
            ex = getattr(ccxt, name)({'enableRateLimit': True, 'timeout': 10000})
            await ex.load_markets()
            EXCHANGES[name] = ex
            logger.info(f"✅ {name}")
        except:
            logger.warning(f"⚠️ {name}")

# ========= ПОЛУЧЕНИЕ ЦЕН (ГИБРИД) =========
async def fetch_all_prices():
    result = {}
    for coin, data in ws_prices.items():
        if time.time() - data.get('timestamp', 0) < 5:
            result[coin] = {data['exchange']: {'bid': data['bid'], 'ask': data['ask'], 'volume': 0, 'last': data['last']}}
    for name, ex in EXCHANGES.items():
        try:
            for coin in TOP_COINS[:200]:
                if coin in result and name in result[coin]:
                    continue
                symbol = f"{coin}/USDT"
                if symbol not in ex.symbols:
                    continue
                ticker = await ex.fetch_ticker(symbol)
                volume = ticker.get('quoteVolume', 0) or ticker.get('baseVolume', 0)
                if volume < 10000:
                    continue
                result[coin] = result.get(coin, {})
                result[coin][name] = {
                    'bid': ticker.get('bid', 0) or ticker.get('last', 0),
                    'ask': ticker.get('ask', 0) or ticker.get('last', 0),
                    'volume': volume,
                    'last': ticker.get('last', 0)
                }
        except: pass
    return result

# ========= АНАЛИЗ =========
def analyze_all_opportunities(prices, settings):
    opportunities = []
    amount = max(settings.get('amount', 100), 10)
    min_spread = settings.get('min_spread', 0.3)
    favorites = settings.get('favorites', [])
    for coin, exchanges in prices.items():
        if favorites and coin not in favorites:
            continue
        if len(exchanges) < 2:
            continue
        exchange_list = list(exchanges.items())
        for i, (buy_ex, buy_data) in enumerate(exchange_list):
            for j, (sell_ex, sell_data) in enumerate(exchange_list):
                if buy_ex == sell_ex:
                    continue
                ask = buy_data.get('ask', 0)
                bid = sell_data.get('bid', 0)
                if ask <= 0 or bid <= 0:
                    continue
                price_ratio = max(bid, ask) / min(bid, ask)
                if price_ratio > 1.5:
                    continue
                spread = (bid - ask) / ask * 100
                if spread > 10 or spread < min_spread:
                    continue
                if not is_same_coin(coin, coin):
                    continue
                volume = min(buy_data.get('volume', 0), sell_data.get('volume', 0))
                if volume < 50000:
                    continue
                buy_fee = EXCHANGE_FEES.get(buy_ex, 0.001)
                sell_fee = EXCHANGE_FEES.get(sell_ex, 0.001)
                network_fee = NETWORK_FEES.get(coin, NETWORK_FEES["DEFAULT"])
                transfer_time = TRANSFER_TIME.get(coin, TRANSFER_TIME["DEFAULT"])
                coins_bought = amount / ask
                sell_value = coins_bought * bid
                gross_profit = sell_value - amount
                total_fees = (amount * buy_fee) + (sell_value * sell_fee) + network_fee
                net_profit = gross_profit - total_fees
                net_profit_pct = (net_profit / amount) * 100
                if net_profit_pct > 20:
                    continue
                if net_profit > 0:
                    save_spread(coin, buy_ex, sell_ex, spread, net_profit, amount, ask, bid)
                    opportunities.append({
                        'coin': coin, 'buy_exchange': buy_ex, 'sell_exchange': sell_ex,
                        'buy_price': round(ask, 8), 'sell_price': round(bid, 8),
                        'spread': round(spread, 2), 'best_amount': amount,
                        'best_profit': round(net_profit, 2), 'best_profit_pct': round(net_profit_pct, 2),
                        'network_fee': network_fee, 'transfer_time': transfer_time,
                        'buy_fee': round(buy_fee * 100, 2), 'sell_fee': round(sell_fee * 100, 2),
                        'volume': round(volume, 0), 'last_price': round(buy_data.get('last', ask), 8)
                    })
    return sorted(opportunities, key=lambda x: x['best_profit'], reverse=True)

def format_opportunity_message(opp):
    return f"🚀 <b>{opp['coin']}/USDT</b>\n\n📊 <b>СПРЕД:</b> {opp['spread']}%\n\n📈 <b>КУПИТЬ:</b> {opp['buy_exchange'].upper()} | ${opp['buy_price']}\n📉 <b>ПРОДАТЬ:</b> {opp['sell_exchange'].upper()} | ${opp['sell_price']}\n\n💰 <b>ПРИБЫЛЬ:</b> +${opp['best_profit']} ({opp['best_profit_pct']}%) с ${opp['best_amount']}\n\n💸 <b>КОМИССИИ:</b> {opp['buy_fee']}% + {opp['sell_fee']}% | Сеть: ${opp['network_fee']} | {opp['transfer_time']} мин\n\n📊 <b>ЛИКВИДНОСТЬ:</b> ${int(opp['volume']):,}"

# ========= TELEGRAM БОТ =========
def send_message(chat_id, text, keyboard=None):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    data = {"chat_id": chat_id, "text": text, "parse_mode": "HTML"}
    if keyboard:
        data["reply_markup"] = keyboard
    try:
        requests.post(url, json=data)
    except: pass

