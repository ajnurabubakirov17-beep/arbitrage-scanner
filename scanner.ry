# ========= ЗАГРУЗКА ТОП-1000 МОНЕТ =========
COINS_CACHE = "coins_cache.json"

def load_top_coins():
    if os.path.exists(COINS_CACHE):
        try:
            with open(COINS_CACHE, 'r') as f:
                data = json.load(f)
                if time.time() - data.get("timestamp", 0) < 86400:
                    coins = data.get("symbols", [])
                    if len(coins) >1000:
                        logging.info(f"📦 Загружено {len(coins)} монет из кэша")
                        return coins
        except:
            pass
    
    top_coins = [
        "BTC", "ETH", "SOL", "BNB", "XRP", "DOGE", "ADA", "AVAX", "DOT", "LINK",
        "MATIC", "UNI", "ATOM", "LTC", "ETC", "FIL", "APT", "ARB", "OP", "VET",
        "ALGO", "NEAR", "ICP", "EGLD", "SAND", "MANA", "GALA", "AAVE", "MKR", "CRV",
        "QNT", "RNDR", "INJ", "TIA", "SEI", "SUI", "PEPE", "WIF", "FLOKI", "BONK",
        "SHIB", "XLM", "HBAR", "FTM", "RUNE", "FLOW", "CHZ", "ENJ", "ZIL", "IOST",
        "KAS", "CFX", "GRT", "SNX", "COMP", "LDO", "RPL", "FXS", "DYDX", "GMX",
        "IMX", "ENS", "BLUR", "STX", "ORDI", "JUP", "PYTH", "ONDO", "STRK", "W"
    ]
    
    try:
        with open(COINS_CACHE, 'w') as f:
            json.dump({"timestamp": time.time(), "symbols": top_coins}, f)
    except:
        pass
    
    return top_coins

