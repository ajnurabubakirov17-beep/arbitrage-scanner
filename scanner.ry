def get_contract_key(coin):
    native_coins = ["BTC", "ETH", "SOL", "BNB", "XRP", "DOGE", "ADA", "AVAX", "DOT", "TRX"]
    if coin in native_coins:
        return f"native_{coin}"
    if coin in CONTRACT_ADDRESSES:
        for network, address in CONTRACT_ADDRESSES[coin].items():
            return f"{coin}_{address[:10]}"
    return coin

def is_same_coin(coin1, coin2):
    if coin1 == coin2:
        return True
    return get_contract_key(coin1) == get_contract_key(coin2)

# ========= БАЗА ДАННЫХ SQLITE =========
DB_FILE = "spreads.db"

def init_db():
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS spreads
                 (id INTEGER PRIMARY KEY AUTOINCREMENT,
                  coin TEXT, buy_exchange TEXT, sell_exchange TEXT,
                  spread REAL, profit REAL, amount REAL,
                  buy_price REAL, sell_price REAL, timestamp INTEGER)''')
    c.execute('''CREATE TABLE IF NOT EXISTS users
                 (id INTEGER PRIMARY KEY AUTOINCREMENT,
                  chat_id INTEGER UNIQUE, favorites TEXT,
                  total_spreads INTEGER DEFAULT 0, total_profit REAL DEFAULT 0,
                  first_seen INTEGER, last_seen INTEGER)''')
    conn.commit()
    conn.close()
    logger.info("📦 База данных инициализирована")

def save_spread(coin, buy_ex, sell_ex, spread, profit, amount, buy_price, sell_price):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("INSERT INTO spreads (coin, buy_exchange, sell_exchange, spread, profit, amount, buy_price, sell_price, timestamp) VALUES (?,?,?,?,?,?,?,?,?)",
                  (coin, buy_ex, sell_ex, spread, profit, amount, buy_price, sell_price, int(time.time())))
        conn.commit()
        conn.close()
    except: pass

def save_user_to_db(chat_id, favorites=None):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("INSERT OR IGNORE INTO users (chat_id, favorites, first_seen, last_seen) VALUES (?, ?, ?, ?)",
                  (chat_id, json.dumps(favorites or []), int(time.time()), int(time.time())))
        c.execute("UPDATE users SET last_seen = ? WHERE chat_id = ?", (int(time.time()), chat_id))
        conn.commit()
        conn.close()
    except: pass

def get_user_favorites(chat_id):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("SELECT favorites FROM users WHERE chat_id = ?", (chat_id,))
        result = c.fetchone()
        conn.close()
        if result and result[0]:
            return json.loads(result[0])
        return []
    except: return []

def update_user_favorites(chat_id, favorites):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("UPDATE users SET favorites = ? WHERE chat_id = ?", (json.dumps(favorites), chat_id))
        conn.commit()
        conn.close()
    except: pass

def get_top_spreads_history(limit=10):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("SELECT coin, buy_exchange, sell_exchange, spread, profit, amount, datetime(timestamp, 'unixepoch') FROM spreads ORDER BY spread DESC LIMIT ?", (limit,))
        result = c.fetchall()
        conn.close()
        return result
    except: return []

def get_spreads_last_24h():
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("SELECT coin, spread, profit, datetime(timestamp, 'unixepoch') FROM spreads WHERE timestamp > ? ORDER BY timestamp DESC LIMIT 100",
                  (int(time.time()) - 86400,))
        result = c.fetchall()
        conn.close()
        return result
    except: return []

# ========= ГРАФИК СПРЕДОВ =========
def generate_spread_chart(coin=None):
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    if coin:
        c.execute("SELECT spread, datetime(timestamp, 'unixepoch') FROM spreads WHERE coin = ? ORDER BY timestamp DESC LIMIT 50", (coin,))
    else:
        c.execute("SELECT spread, datetime(timestamp, 'unixepoch') FROM spreads ORDER BY timestamp DESC LIMIT 100")
    data = c.fetchall()
    conn.close()
    if not data:
        return None
    spreads = [row[0] for row in reversed(data)]
    times = [row[1] for row in reversed(data)]
    plt.figure(figsize=(10, 5))
    plt.plot(times, spreads, marker='o', linestyle='-', color='green', linewidth=2)
    plt.title(f'Спреды {"для " + coin if coin else "за последнее время"}')
    plt.xlabel('Время')
    plt.ylabel('Спред (%)')
    plt.xticks(rotation=45)
    plt.tight_layout()
    buf = BytesIO()
    plt.savefig(buf, format='png')
    buf.seek(0)
    plt.close()
    return buf

