def run_bot():
    global last_update_id
    
    logger.info("🤖 Telegram бот запущен, жду команды...")
    
    while True:
        try:
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates"
            resp = requests.get(url, params={"offset": last_update_id + 1, "timeout": 30})
            data = resp.json()
            
            if not data.get("ok"):
                continue
                
            for update in data.get("result", []):
                last_update_id = update["update_id"] + 1
                
                # Сообщения
                msg = update.get("message")
                if msg:
                    chat_id = msg["chat"]["id"]
                    text = msg.get("text", "")
                    is_admin = (chat_id == ADMIN_ID)
                    
                    if chat_id not in USERS:
                        USERS[chat_id] = {
                            "active": False,
                            "amount": 100,
                            "min_spread": 0.3,
                            "last_alerts": {}
                        }
                    
                    if text == "/start":
                        show_main_menu(chat_id, is_admin)
                    elif text == "/admin" and is_admin:
                        show_admin_panel(chat_id)
                
                # Кнопки
                callback = update.get("callback_query")
                if callback:
                    chat_id = callback["message"]["chat"]["id"]
                    data_cb = callback["data"]
                    is_admin = (chat_id == ADMIN_ID)
                    
                    if chat_id not in USERS:
                        USERS[chat_id] = {
                            "active": False,
                            "amount": 100,
                            "min_spread": 0.3,
                            "last_alerts": {}
                        }
                    
                    user = USERS[chat_id]
                    
                    # ===== ОСНОВНЫЕ КНОПКИ =====
                    if data_cb == "start":
                        user["active"] = True
                        send_message(chat_id, "✅ <b>СКАНИРОВАНИЕ ЗАПУЩЕНО!</b>\n\nЯ буду присылать уведомления о найденных спредах.")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "stop":
                        user["active"] = False
                        send_message(chat_id, "⏹️ <b>СКАНИРОВАНИЕ ОСТАНОВЛЕНО!</b>")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "show_all":
                        send_message(chat_id, "🔍 <b>ПОИСК СПРЕДОВ...</b>\n\nПожалуйста, подождите 10-20 секунд.")
                        
                        if last_prices:
                            opps = analyze_all_opportunities(last_prices, user)
                            if opps:
                                for opp in opps[:10]:
                                    msg = format_opportunity_message(opp)
                                    send_message(chat_id, msg)
                                send_message(chat_id, f"📊 <b>ВСЕГО НАЙДЕНО СПРЕДОВ: {len(opps)}</b>")
                            else:
                                send_message(chat_id, "😴 <b>СПРЕДОВ НЕ НАЙДЕНО</b>\n\nПопробуйте:\n• Увеличить сумму\n• Уменьшить min спред")
                        else:
                            send_message(chat_id, "🔄 <b>ДАННЫЕ ЗАГРУЖАЮТСЯ...</b>\n\nПодождите 30 секунд и попробуйте снова.")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "change_amount":
                        show_amount_keyboard(chat_id)
                    
                    elif data_cb.startswith("amt_"):
                        amount = int(data_cb.replace("amt_", ""))
                        user["amount"] = amount
                        send_message(chat_id, f"✅ <b>СУММА УСТАНОВЛЕНА: ${amount}</b>")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "change_spread":
                        show_spread_keyboard(chat_id)
                    
                    elif data_cb.startswith("spread_"):
                        spread = float(data_cb.replace("spread_", "")) / 100
                        user["min_spread"] = spread
                        send_message(chat_id, f"✅ <b>MIN СПРЕД УСТАНОВЛЕН: {spread}%</b>")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "top_spreads":
                        send_message(chat_id, "🏆 <b>ПОЛУЧАЮ ТОП-10 СПРЕДОВ...</b>")
                        
                        if last_prices:
                            opps = analyze_all_opportunities(last_prices, user)
                            if opps:
                                top_text = "🏆 <b>ТОП-10 АРБИТРАЖНЫХ ВОЗМОЖНОСТЕЙ</b>\n\n"
                                for i, opp in enumerate(opps[:10], 1):
                                    top_text += f"{i}. <b>{opp['coin']}/USDT</b>\n"
                                    top_text += f"   📈 {opp['buy_exchange'].upper()} → {opp['sell_exchange'].upper()}\n"
                                    top_text += f"   📊 Спред: {opp['spread']}%\n"
                                    top_text += f"   💰 Прибыль: +${opp['best_profit']} (с ${opp['best_amount']})\n\n"
                                send_message(chat_id, top_text)
                            else:
                                send_message(chat_id, "😴 <b>СПРЕДОВ НЕ НАЙДЕНО</b>")
                        else:
                            send_message(chat_id, "🔄 Данные загружаются...")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "status":
                        active = "Да ✅" if user["active"] else "Нет ⏹️"
                        status_text = f"""
📊 <b>СТАТУС СКАНЕРА</b>

🟢 <b>УВЕДОМЛЕНИЯ:</b> {active}
💰 <b>СУММА:</b> ${user['amount']}
🎯 <b>MIN СПРЕД:</b> {user['min_spread']}%
🏦 <b>БИРЖ:</b> {len(EXCHANGES)} активных
🪙 <b>МОНЕТ:</b> {len(TOP_COINS)}
📊 <b>ОБНОВЛЕНИЕ:</b> каждые 15 секунд
"""
                        send_message(chat_id, status_text)
                        show_main_menu(chat_id, is_admin)
                    
                    # ===== АДМИН-КНОПКИ =====
                    elif data_cb == "admin_panel" and is_admin:
                        show_admin_panel(chat_id)
                    
                    elif data_cb == "admin_stats" and is_admin:
                        active_count = sum(1 for u in USERS.values() if u.get("active"))
                        stats = f"""
📊 <b>СТАТИСТИКА СЕРВЕРА</b>

👥 <b>ПОЛЬЗОВАТЕЛИ:</b> {len(USERS)}
🟢 <b>АКТИВНЫХ:</b> {active_count}
🪙 <b>МОНЕТ:</b> {len(TOP_COINS)}
🏦 <b>БИРЖ:</b> {len(EXCHANGES)}
🔄 <b>АВТОПИНГ:</b> активен (каждые 2 мин)
"""
                        send_message(chat_id, stats)
                        show_admin_panel(chat_id)
                    
                    elif data_cb == "admin_users" and is_admin:
                        users_list = "👥 <b>СПИСОК ПОЛЬЗОВАТЕЛЕЙ</b>\n\n"
                        for uid, u in USERS.items():
                            users_list += f"• ID: {uid}\n  Активен: {'✅' if u.get('active') else '⏹️'}\n  Сумма: ${u.get('amount', 100)}\n  Min спред: {u.get('min_spread', 0.3)}%\n\n"
                        send_message(chat_id, users_list[:4000])
                        show_admin_panel(chat_id)
                    
                    elif data_cb == "admin_refresh" and is_admin:
                        send_message(chat_id, "🔄 <b>ПРИНУДИТЕЛЬНОЕ ОБНОВЛЕНИЕ...</b>")
                        if os.path.exists(COINS_CACHE_FILE):
                            os.remove(COINS_CACHE_FILE)
                        send_message(chat_id, "✅ Кэш очищен. Монеты обновятся при следующем сканировании.")
                        show_admin_panel(chat_id)
                    
                    elif data_cb == "help":
                        help_text = """
ℹ️ <b>ПОМОЩЬ ПО СКАНЕРУ</b>

<b>🔍 КАК ЭТО РАБОТАЕТ:</b>
Сканер каждые 15 секунд проверяет цены на 11 биржах для ВСЕХ монет и ищет арбитражные возможности.

<b>📨 ПОЛУЧЕНИЕ СПРЕДОВ:</b>
• <b>АВТОМАТИЧЕСКИ:</b> нажмите "ЗАПУСТИТЬ"
• <b>ВРУЧНУЮ:</b> нажмите "ПОКАЗАТЬ ВСЕ СПРЕДЫ"

<b>⚙️ НАСТРОЙКИ:</b>
• <b>Сумма:</b> от $10 до $10000 (влияет на расчёт прибыли)
• <b>Min спред:</b> минимальный процент для уведомления

<b>💡 ЧТО УЧИТЫВАЕТСЯ:</b>
✅ Комиссии бирж (0.1-0.6%)
✅ Комиссии сети перевода ($0.5-$5)
✅ Время перевода (1-30 мин)
✅ Ликвидность (объем торгов >$10k)
✅ Контракты монет (не путает разные монеты)

<b>👑 АДМИН:</b> @ваш_username
"""
                        send_message(chat_id, help_text)
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "back":
                        show_main_menu(chat_id, is_admin)
                    
                    # Ответ на нажатие
                    requests.post(
                        f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/answerCallbackQuery",
                        json={"callback_query_id": callback["id"]}
                    )
                    
        except Exception as e:
            logger.error(f"Telegram error: {e}")
        
        time.sleep(1)

# ========= ОСНОВНОЙ СКАНЕР =========
async def main_scanner():
    global last_prices, TOP_COINS
    
    logger.info("🚀 ОСНОВНОЙ СКАНЕР ЗАПУЩЕН")
    
    # Загружаем монеты
    TOP_COINS = await load_coins_from_exchanges()
    logger.info(f"🎯 ЗАГРУЖЕНО {len(TOP_COINS)} МОНЕТ ДЛЯ АНАЛИЗА")
    
    # Обновляем количество монет у пользователей
    for chat_id in USERS:
        USERS[chat_id]["total_coins"] = len(TOP_COINS)
    
    while True:
        try:
            start_time = time.time()
            
            # Получаем цены
            prices = await fetch_all_prices()
            last_prices = prices
            
            # Отправляем уведомления активным пользователям
            for chat_id, user in USERS.items():
                if user.get("active", False):
                    opportunities = analyze_all_opportunities(prices, user)
                    
                    for opp in opportunities[:5]:  # Топ-5 для уведомлений
                        key = f"{opp['coin']}_{opp['buy_exchange']}_{opp['sell_exchange']}"
                        now = time.time()
                        
                        # Анти-спам: не чаще 5 минут на один спред
                        if key in user["last_alerts"] and now - user["last_alerts"][key] < 300:
                            continue
                        
                        user["last_alerts"][key] = now
                        msg = format_opportunity_message(opp)
                        send_message(chat_id, msg)
            
            elapsed = time.time() - start_time
            logger.info(f"✅ Сканирование {len(TOP_COINS)} монет завершено за {elapsed:.1f} сек")
            
        except Exception as e:
            logger.error(f"❌ Ошибка сканера: {e}")
        
        await asyncio.sleep(15)  # Сканируем каждые 15 секунд

# ========= ЗАПУСК =========
async def main():
    # Инициализируем биржи
    await init_exchanges()
    
    logger.info("=" * 60)
    logger.info("🚀 ПРОФЕССИОНАЛЬНЫЙ АРБИТРАЖНЫЙ СКАНЕР")
    logger.info("=" * 60)
    logger.info(f"🏦 БИРЖ: {len(EXCHANGES)} из {len(EXCHANGES_LIST)}")
    logger.info(f"🔄 АВТОПИНГ: активен (каждые 2 минуты)")
    logger.info(f"👑 АДМИН: {ADMIN_ID}")
    logger.info("=" * 60)
    
    # Запускаем веб-сервер
    threading.Thread(target=run_web, daemon=True).start()
    
    # Запускаем улучшенный автопинг
    threading.Thread(target=keep_alive, daemon=True).start()
    
    # Запускаем Telegram бота
    threading.Thread(target=run_bot, daemon=True).start()
    
    # Запускаем основной сканер
    await main_scanner()

if __name__ == "__main__":
    asyncio.run(main())
