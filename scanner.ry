def get_contract_key(coin):
    """Возвращает ключ для сравнения контрактов"""
    native_coins = ["BTC", "ETH", "SOL", "BNB", "XRP", "DOGE", "ADA", "AVAX", "DOT", "TRX"]
    if coin in native_coins:
        return f"native_{coin}"
    if coin in CONTRACT_ADDRESSES:
        for network, address in CONTRACT_ADDRESSES[coin].items():
            return f"{coin}_{address[:10]}"
    return coin

def is_same_coin(coin1, coin2):
    """Проверяет, что это одна и та же монета по контракту"""
    if coin1 == coin2:
        return True
    return get_contract_key(coin1) == get_contract_key(coin2)

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

EXCHANGES = {}
