def confirm_payment(chat_id, plan_id, txid):
    plan = PLANS.get(plan_id)
    if not plan:
        send_message(chat_id, "❌ Неверный тариф")
        return False
    
    paid_until = int(time.time()) + (plan["days"] * 86400)
    if save_subscription(chat_id, plan_id, paid_until, plan["price_usd"], txid):
        send_message(chat_id, f"✅ Подписка <b>{plan['name']}</b> активирована!\nДействует до: {datetime.fromtimestamp(paid_until).strftime('%d.%m.%Y')}")
        
        # Начисляем бонус рефереру
        ref_info = get_user_referral_info(chat_id)
        referrer_id = ref_info.get("referred_by")
        if referrer_id:
            bonus = plan["price_usd"] * 0.2
            add_referral_earnings(referrer_id, bonus)
            send_message(referrer_id, f"🎉 Ваш реферал оформил подписку! Вы получили ${bonus:.2f} на баланс!")
            
            # Проверяем бонусы за количество рефералов
            refs = load_referrals()
            total_refs = len(refs.get(str(referrer_id), {}).get("referrals", []))
            if total_refs >= 20:
                save_subscription(referrer_id, "lifetime", 9999999999, 0, "bonus")
                send_message(referrer_id, "🏆 ПОЗДРАВЛЯЕМ! Вы достигли 20 рефералов и получили БЕССРОЧНУЮ ПОДПИСКУ!")
            elif total_refs >= 10:
                current_sub = get_user_subscription(referrer_id)
                current_until = current_sub[1] if current_sub else int(time.time())
                new_until = max(current_until, int(time.time())) + (30 * 86400)
                save_subscription(referrer_id, "month", new_until, 0, "bonus_10")
                send_message(referrer_id, "🎁 ПОЗДРАВЛЯЕМ! Вы достигли 10 рефералов и получили +30 дней подписки!")
            elif total_refs >= 5:
                current_sub = get_user_subscription(referrer_id)
                current_until = current_sub[1] if current_sub else int(time.time())
                new_until = max(current_until, int(time.time())) + (7 * 86400)
                save_subscription(referrer_id, "week", new_until, 0, "bonus_5")
                send_message(referrer_id, "🎁 ПОЗДРАВЛЯЕМ! Вы достигли 5 рефералов и получили +7 дней подписки!")
        
        return True
    return False

# ========= РЕФЕРАЛЬНАЯ СИСТЕМА =========
REFERRALS_FILE = "referrals.json"
REFERRAL_REWARD_PERCENT = 20

def load_referrals():
    if os.path.exists(REFERRALS_FILE):
        try:
            with open(REFERRALS_FILE, 'r') as f:
                return json.load(f)
        except:
            pass
    return {}

def save_referrals(data):
    with open(REFERRALS_FILE, 'w') as f:
        json.dump(data, f)

def get_user_referral_info(chat_id):
    refs = load_referrals()
    if str(chat_id) in refs:
        return refs[str(chat_id)]
    return {"referred_by": None, "referrals": [], "earnings": 0}

def add_referral(chat_id, referrer_id):
    if chat_id == referrer_id:
        return
    refs = load_referrals()
    if str(referrer_id) not in refs:
        refs[str(referrer_id)] = {"referred_by": None, "referrals": [], "earnings": 0}
    if str(chat_id) not in refs:
        refs[str(chat_id)] = {"referred_by": referrer_id, "referrals": [], "earnings": 0}
    if chat_id not in refs[str(referrer_id)]["referrals"]:
        refs[str(referrer_id)]["referrals"].append(chat_id)
    save_referrals(refs)

def add_referral_earnings(referrer_id, amount):
    refs = load_referrals()
    if str(referrer_id) in refs:
        refs[str(referrer_id)]["earnings"] += amount
        save_referrals(refs)

def generate_referral_link(chat_id):
    return f"https://t.me/Scanner_AD01_bot?start=ref_{chat_id}"

def show_referral_menu(chat_id):
    ref_info = get_user_referral_info(chat_id)
    referral_link = generate_referral_link(chat_id)
    total_referrals = len(ref_info.get("referrals", []))
    total_earnings = ref_info.get("earnings", 0)
    referrals_list = ""
    if total_referrals > 0:
        referrals_list = "\n👥 <b>Ваши рефералы:</b>\n"
        for ref_id in ref_info.get("referrals", [])[:10]:
            try:
                user_info = requests.get(f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getChat", params={"chat_id": ref_id}).json()
                name = user_info.get("result", {}).get("first_name", str(ref_id))
            except:
                name = str(ref_id)
            referrals_list += f"• {name}\n"
        if total_referrals > 10:
            referrals_list += f"... и ещё {total_referrals - 10}\n"
    text = f"🎁 <b>РЕФЕРАЛЬНАЯ ПРОГРАММА</b>\n\n🔗 <b>Ваша ссылка:</b>\n<code>{referral_link}</code>\n\n📊 <b>Статистика:</b>\n• Приглашено: <b>{total_referrals}</b>\n• Заработано: <b>${total_earnings:.2f}</b>{referrals_list}\n\n💰 <b>Бонусы:</b>\n• За 5 рефералов → +7 дней\n• За 10 рефералов → +30 дней\n• За 20 рефералов → бессрочно\n\n💎 <b>Вы получаете 20% от платежа каждого реферала!</b>"
    keyboard = {"inline_keyboard": [[{"text": "📋 СКОПИРОВАТЬ", "callback_data": "copy_link"}], [{"text": "📊 СТАТИСТИКА", "callback_data": "referral_stats"}], [{"text": "🔙 НАЗАД", "callback_data": "back"}]]}
    send_message(chat_id, text, json.dumps(keyboard))

def show_referral_stats(chat_id):
    ref_info = get_user_referral_info(chat_id)
    total_referrals = len(ref_info.get("referrals", []))
    total_earnings = ref_info.get("earnings", 0)
    bonus = ""
    if total_referrals >= 20:
        bonus = "🏆 <b>БЕССРОЧНАЯ ПОДПИСКА АКТИВНА!</b>"
    elif total_referrals >= 10:
        bonus = "🎁 <b>+30 ДНЕЙ ПОДПИСКИ</b> (достигнуто 10 рефералов)"
    elif total_referrals >= 5:
        bonus = "🎁 <b>+7 ДНЕЙ ПОДПИСКИ</b> (достигнуто 5 рефералов)"
    else:
        bonus = f"🎯 До бонуса осталось: {5 - total_referrals} рефералов"
    text = f"📊 <b>ДЕТАЛЬНАЯ СТАТИСТИКА</b>\n\n👥 Рефералов: {total_referrals}\n💰 Заработано: ${total_earnings:.2f}\n{bonus}"
    keyboard = {"inline_keyboard": [[{"text": "🔙 НАЗАД", "callback_data": "referral_menu"}]]}
    send_message(chat_id, text, json.dumps(keyboard))

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

EXCHANGES = {}
USERS = {}
last_prices = {}
last_update_id = 0
COINS_CACHE_FILE = "coins_cache.json"
TOP_COINS = []

# ========= ЗАГРУЗКА МОНЕТ С БИРЖ =========
async def load_coins_from_exchanges():
    if os.path.exists(COINS_CACHE_FILE):
        try:
            with open(COINS_CACHE_FILE, 'r') as f:
                data = json.load(f)
                if time.time() - data.get("timestamp", 0) < 86400:
                    coins = data.get("symbols", [])
                    if len(coins) > 100:
                        logger.info(f"📦 Загружено {len(coins)} монет из кэша")
                        return coins
        except: pass
    logger.info("🔄 Сбор ВСЕХ монет с бирж...")
    all_coins = set()
    for name, exchange in EXCHANGES.items():
        try:
            markets = await exchange.load_markets()
            count = 0
            for symbol in markets:
                if '/USDT' in symbol.upper():
                    coin = symbol.upper().replace('/USDT', '').split(':')[0]
                    coin = ''.join(c for c in coin if c.isalnum())
                    if len(coin) <= 10 and coin not in all_coins:
                        all_coins.add(coin)
                        count += 1
            logger.info(f"  ✅ {name}: +{count} монет")
        except: pass
    coins_list = sorted(list(all_coins))
    logger.info(f"🎯 ВСЕГО СОБРАНО МОНЕТ: {len(coins_list)}")
    try:
        with open(COINS_CACHE_FILE, 'w') as f:
            json.dump({"timestamp": time.time(), "symbols": coins_list}, f)
    except: pass
    return coins_list

