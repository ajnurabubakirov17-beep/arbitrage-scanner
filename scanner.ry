            [{"text": "🔍 ПОКАЗАТЬ ВСЕ СПРЕДЫ", "callback_data": "show_all"}],
            [{"text": "⭐ ИЗБРАННЫЕ МОНЕТЫ", "callback_data": "favorites_menu"}],
            [{"text": "💰 СУММА", "callback_data": "change_amount"}, {"text": "🎯 MIN СПРЕД", "callback_data": "change_spread"}],
            [{"text": "📊 СТАТУС", "callback_data": "status"}, {"text": "🏆 ТОП-10 СПРЕДОВ", "callback_data": "top_spreads"}],
            [{"text": "📈 ГРАФИК СПРЕДОВ", "callback_data": "chart"}, {"text": "📜 ИСТОРИЯ", "callback_data": "history"}],
            [{"text": "🎁 РЕФЕРАЛЬНАЯ ПРОГРАММА", "callback_data": "referral_menu"}],
            [{"text": "💎 ПОДПИСКА", "callback_data": "subscription_menu"}],
            [{"text": "ℹ️ ПОМОЩЬ", "callback_data": "help"}]
        ]
    }
    if is_admin:
        keyboard["inline_keyboard"].append([{"text": "👑 АДМИН", "callback_data": "admin_panel"}])
    
    warning = ""
    if not has_subscription and not is_admin:
