def get_user_subscription(chat_id):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("SELECT plan, paid_until, amount, txid, payment_date FROM subscriptions WHERE chat_id = ?", (chat_id,))
        result = c.fetchone()
        conn.close()
        if result:
            return {"plan": result[0], "paid_until": result[1], "amount": result[2], "txid": result[3], "payment_date": result[4]}
        return None
    except: return None

def save_subscription(chat_id, plan, paid_until, amount, txid):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("INSERT OR REPLACE INTO subscriptions (chat_id, plan, paid_until, amount, txid, payment_date) VALUES (?, ?, ?, ?, ?, ?)",
                  (chat_id, plan, paid_until, amount, txid, int(time.time())))
        conn.commit()
        conn.close()
        return True
    except: return False

def check_subscription(chat_id):
    if chat_id == ADMIN_ID:
        return True
    sub = get_user_subscription(chat_id)
    if sub and sub["paid_until"] > time.time():
        return True
    return False

def get_subscription_status_text(chat_id):
    if chat_id == ADMIN_ID:
        return "👑 АДМИН — полный доступ"
    sub = get_user_subscription(chat_id)
    if sub and sub["paid_until"] > time.time():
        days_left = int((sub["paid_until"] - time.time()) / 86400)
        return f"✅ {PLANS.get(sub['plan'], {}).get('name', 'Активна')} до {datetime.fromtimestamp(sub['paid_until']).strftime('%d.%m.%Y')} (осталось {days_left} дн.)"
    return "❌ Нет активной подписки"

