def show_favorites_menu(chat_id):
    favorites = get_user_favorites(chat_id)
    top_coins = TOP_COINS[:30] if TOP_COINS else ["BTC", "ETH", "SOL", "BNB", "XRP", "DOGE", "ADA", "AVAX", "DOT", "LINK"]
    
    keyboard = {"inline_keyboard": []}
    for coin in top_coins:
        status = "✅" if coin in favorites else "❌"
        keyboard["inline_keyboard"].append([{"text": f"{status} {coin}", "callback_data": f"fav_{coin}"}])
    keyboard["inline_keyboard"].append([{"text": "🔙 НАЗАД", "callback_data": "back"}])
    
    text = f"⭐ <b>ИЗБРАННЫЕ МОНЕТЫ</b>\n\nТекущие: {', '.join(favorites[:10]) if favorites else 'не выбраны'}\n\nВыберите монеты:"
    send_message(chat_id, text, json.dumps(keyboard))

def show_history(chat_id):
    top_spreads = get_top_spreads_history(10)
    if not top_spreads:
        send_message(chat_id, "📜 История спредов пуста")
        return
    text = "📜 <b>ТОП-10 СПРЕДОВ ЗА ВСЁ ВРЕМЯ</b>\n\n"
    for i, (coin, buy_ex, sell_ex, spread, profit, amount, date) in enumerate(top_spreads, 1):
        text += f"{i}. <b>{coin}</b> | {buy_ex} → {sell_ex}\n   📊 {spread:.2f}% | 💰 +${profit:.2f} (с ${amount})\n   🕐 {date}\n\n"
    send_message(chat_id, text)

