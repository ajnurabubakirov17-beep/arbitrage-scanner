def run_bot():
    global last_update_id
    logger.info("🤖 Telegram бот запущен")
    
    while True:
        try:
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates"
            resp = requests.get(url, params={"offset": last_update_id + 1, "timeout": 30})
            data = resp.json()
            
            if not data.get("ok"):
                continue
                
            for update in data.get("result", []):
                last_update_id = update["update_id"] + 1
                
                # Обработка сообщений
                msg = update.get("message")
                if msg:
                    chat_id = msg["chat"]["id"]
                    is_admin = (chat_id == ADMIN_ID)
                    text = msg.get("text", "")
                    
                    if chat_id not in USERS:
                        USERS[chat_id] = {"active": False, "amount": 100, "min_spread": 0.3, "last_alerts": {}}
                        save_user_to_db(chat_id)
                    
                    if text == "/start":
                        if "ref_" in text:
                            try:
                                referrer_id = int(text.split("ref_")[1])
                                if referrer_id != chat_id:
                                    add_referral(chat_id, referrer_id)
                                    send_message(chat_id, "🎉 Вы зарегистрировались по реферальной ссылке!")
                                    send_message(referrer_id, "🎉 По вашей ссылке зарегистрировался новый пользователь!")
                            except: pass
                        show_main_menu(chat_id, is_admin)
                    
                    elif text.startswith("/confirm"):
                        parts = text.split()
                        if len(parts) >= 3:
                            plan_id = parts[1]
                            txid = parts[2]
                            if confirm_payment(chat_id, plan_id, txid):
                                send_message(chat_id, "✅ Подписка активирована!")
                            else:
                                send_message(chat_id, "❌ Ошибка активации")
                        else:
                            send_message(chat_id, "Использование: /confirm plan_id TXID")
                
                # Обработка callback-запросов
                callback = update.get("callback_query")
                if callback:
                    chat_id = callback["message"]["chat"]["id"]
                    message_id = callback["message"]["message_id"]
                    data_cb = callback["data"]
                    is_admin = (chat_id == ADMIN_ID)
                    
                    if chat_id not in USERS:
                        USERS[chat_id] = {"active": False, "amount": 100, "min_spread": 0.3, "last_alerts": {}}
                        save_user_to_db(chat_id)
                    
                    user = USERS[chat_id]
                    
                    # ОТВЕЧАЕМ НА CALLBACK (убираем задержку)
                    try:
                        requests.post(
                            f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/answerCallbackQuery",
                            json={"callback_query_id": callback["id"]},
                            timeout=3
                        )
                    except:
                        pass
                    
                    # Обработка кнопок
                    if data_cb == "start":
                        if check_subscription(chat_id):
                            user["active"] = True
                            send_message(chat_id, "✅ Уведомления ВКЛЮЧЕНЫ!")
                        else:
                            send_message(chat_id, "❌ Оформите подписку!")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "stop":
                        user["active"] = False
                        send_message(chat_id, "⏹️ Уведомления ВЫКЛЮЧЕНЫ!")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "show_all":
                        if not check_subscription(chat_id) and not is_admin:
                            send_message(chat_id, "❌ Оформите подписку!")
                            show_main_menu(chat_id, is_admin)
                            continue
                        send_message(chat_id, "🔍 ИЩУ СПРЕДЫ...")
                        if last_prices:
                            favorites = get_user_favorites(chat_id)
                            opps = analyze_all_opportunities(last_prices, {**user, "favorites": favorites})
                            if opps:
                                for opp in opps[:10]:
                                    send_message(chat_id, format_opportunity_message(opp))
                                send_message(chat_id, f"📊 Найдено {len(opps)} спредов")
                            else:
                                send_message(chat_id, "😴 Спредов нет")
                        else:
                            send_message(chat_id, "🔄 Данные загружаются...")
                        show_main_menu(chat_id, is_admin)
                    
                    elif data_cb == "favorites_menu":
                        show_favorites_menu(chat_id)
                    
                    elif data_cb.startswith("fav_"):
                        coin = data_cb.replace("fav_", "")
                        favorites = get_user_favorites(chat_id)
                        if coin in favorites:
                            favorites.remove(coin)
                            send_message(chat_id, f"❌ {coin} удалён")
                        else:
