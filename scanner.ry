# ========= ЗАПУСК =========
async def main():
    # Инициализируем биржи
    await init_exchanges()
    
    # Запускаем веб-сервер для автопинга
    threading.Thread(target=run_web_server, daemon=True).start()
    threading.Thread(target=keep_alive, daemon=True).start()
    
    logger.info("=" * 60)
    logger.info("🚀 ПРОФЕССИОНАЛЬНЫЙ АРБИТРАЖНЫЙ СКАНЕР")
    logger.info("=" * 60)
    logger.info(f"📊 МОНЕТ: {len(BASE_COINS)}")
    logger.info(f"🏦 БИРЖ: {len(EXCHANGES)} из {len(EXCHANGES_LIST)}")
    logger.info(f"🔄 АВТОПИНГ: активен (каждые 5 минут)")
    logger.info(f"📨 УВЕДОМЛЕНИЯ: только по запросу пользователя")
    logger.info("=" * 60)
    
    # Запускаем фоновый сканер
    asyncio.create_task(background_scanner())
    
    # Создаем приложение Telegram
    app = Application.builder().token(TELEGRAM_TOKEN).build()
    
    # Регистрируем обработчики
    app.add_handler(CommandHandler("start", start_command))
    app.add_handler(CallbackQueryHandler(button_callback))
    
    # Запускаем проверку уведомлений каждые 10 секунд
    async def notification_loop():
        while True:
            await check_and_notify_users(app)
            await asyncio.sleep(10)
    
    asyncio.create_task(notification_loop())
    
    # Запускаем бота
    await app.initialize()
    await app.start()
    await app.updater.start_polling()
    await app.updater.idle()

if __name__ == "__main__":
    asyncio.run(main())
