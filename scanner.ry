PLANS = {
    "week": {"name": "Неделя", "days": 7, "price": 5, "price_usd": 5},
    "month": {"name": "Месяц", "days": 30, "price": 20, "price_usd": 20},
    "3months": {"name": "3 Месяца", "days": 90, "price": 50, "price_usd": 50},
    "year": {"name": "Год", "days": 365, "price": 100, "price_usd": 100},
    "lifetime": {"name": "Бессрочно", "days": 36500, "price": 350, "price_usd": 350}
}

def get_user_subscription(chat_id):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("SELECT plan, paid_until, amount, txid, payment_date FROM subscriptions WHERE chat_id = ?", (chat_id,))
        result = c.fetchone()
        conn.close()
        if result:
            return {"plan": result[0], "paid_until": result[1], "amount": result[2], "txid": result[3], "payment_date": result[4]}
        return None
    except:
        return None

def save_subscription(chat_id, plan, paid_until, amount, txid):
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("INSERT OR REPLACE INTO subscriptions (chat_id, plan, paid_until, amount, txid, payment_date) VALUES (?, ?, ?, ?, ?, ?)",
                  (chat_id, plan, paid_until, amount, txid, int(time.time())))
        conn.commit()
        conn.close()
        return True
    except:
        return False

def check_subscription(chat_id):
    # АДМИН — ВСЕГДА ДОСТУП БЕЗ ПОДПИСКИ
    if chat_id == ADMIN_ID:
        return True
    
    sub = get_user_subscription(chat_id)
    if sub and sub[1] > time.time():
        return True
    return False

def get_subscription_status_text(chat_id):
    if chat_id == ADMIN_ID:
        return "👑 АДМИН — полный доступ без подписки"
    
    sub = get_user_subscription(chat_id)
    if sub:
        paid_until = sub[1]
        plan = sub[0]
        if paid_until > time.time():
            days_left = int((paid_until - time.time()) / 86400)
            return f"✅ План: {PLANS.get(plan, {}).get('name', plan)}\nДействует до: {datetime.fromtimestamp(paid_until).strftime('%d.%m.%Y')} (осталось {days_left} дн.)"
        else:
            return "⏰ Подписка закончилась. Оформите новую!"
    return "❌ Нет активной подписки"

def generate_payment_link(chat_id, plan_id):
    """Генерирует ссылку для оплаты через CryptoBot"""
    plan = PLANS.get(plan_id)
    if not plan:
        return None
    # Формат ссылки для CryptoBot
    amount = plan["price_usd"]
    return f"https://t.me/CryptoBot?start=pay_{amount}_{chat_id}_{plan_id}"

