# ========= РЕФЕРАЛЬНАЯ СИСТЕМА =========
REFERRALS_FILE = "referrals.json"
REFERRAL_REWARD_PERCENT = 20

def load_referrals():
    if os.path.exists(REFERRALS_FILE):
        try:
            with open(REFERRALS_FILE, 'r') as f:
                return json.load(f)
        except: pass
    return {}

def save_referrals(data):
    with open(REFERRALS_FILE, 'w') as f:
        json.dump(data, f)

def get_user_referral_info(chat_id):
    refs = load_referrals()
    if str(chat_id) in refs:
        return refs[str(chat_id)]
    return {"referred_by": None, "referrals": [], "earnings": 0}

def add_referral(chat_id, referrer_id):
    if chat_id == referrer_id:
        return
    refs = load_referrals()
    if str(referrer_id) not in refs:
        refs[str(referrer_id)] = {"referred_by": None, "referrals": [], "earnings": 0}
    if str(chat_id) not in refs:
        refs[str(chat_id)] = {"referred_by": referrer_id, "referrals": [], "earnings": 0}
    if chat_id not in refs[str(referrer_id)]["referrals"]:
        refs[str(referrer_id)]["referrals"].append(chat_id)
    save_referrals(refs)

def add_referral_earnings(referrer_id, amount):
    refs = load_referrals()
    if str(referrer_id) in refs:
        refs[str(referrer_id)]["earnings"] += amount
        save_referrals(refs)

def generate_referral_link(chat_id):
    return f"https://t.me/Scanner_AD01_bot?start=ref_{chat_id}"

# ========= WEBSOCKET ДЛЯ РЕАЛЬНОГО ВРЕМЕНИ =========
ws_prices = {}
ws_tasks = []

async def binance_ws_stream():
    symbols = ["btcusdt", "ethusdt", "solusdt", "bnbusdt", "xrpusdt", "dogeusdt", "adausdt", "avaxusdt", "dotusdt", "linkusdt"]
    stream_names = [f"{s}@ticker" for s in symbols]
    stream_url = "wss://stream.binance.com:9443/ws/" + "/".join(stream_names)
    while True:
        try:
            async with websockets.connect(stream_url) as ws:
                while True:
                    try:
                        msg = await asyncio.wait_for(ws.recv(), timeout=30)
                        data = json.loads(msg)
                        coin = data.get('s', '').replace('USDT', '').upper()
                        ws_prices[coin] = {
                            'bid': float(data.get('b', 0)),
                            'ask': float(data.get('a', 0)),
                            'last': float(data.get('c', 0)),
                            'exchange': 'binance',
                            'timestamp': time.time()
                        }
                    except asyncio.TimeoutError:
                        continue
        except Exception as e:
            logger.error(f"Binance WS: {e}")
            await asyncio.sleep(5)

async def start_websockets():
    asyncio.create_task(binance_ws_stream())
    logger.info("⚡ WebSocket стримы запущены")

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

EXCHANGES = {}
USERS = {}
last_prices = {}
last_update_id = 0
COINS_CACHE_FILE = "coins_cache.json"
TOP_COINS = []

# ========= ЗАГРУЗКА МОНЕТ =========
async def load_coins_from_exchanges():
    if os.path.exists(COINS_CACHE_FILE):
        try:
            with open(COINS_CACHE_FILE, 'r') as f:
                data = json.load(f)
                if time.time() - data.get("timestamp", 0) < 86400:
                    coins = data.get("symbols", [])
                    if len(coins) > 100:
                        logger.info(f"📦 Загружено {len(coins)} монет из кэша")
                        return coins
        except: pass
    logger.info("🔄 Сбор монет с бирж...")
    all_coins = set()
    for name, exchange in EXCHANGES.items():
        try:
            markets = await exchange.load_markets()
            for symbol in markets:
                if '/USDT' in symbol.upper():
                    coin = symbol.upper().replace('/USDT', '').split(':')[0]
                    coin = ''.join(c for c in coin if c.isalnum())
                    if len(coin) <= 10 and coin not in all_coins:
                        all_coins.add(coin)
            logger.info(f"  ✅ {name}")
        except: pass
    coins_list = sorted(list(all_coins))
    logger.info(f"🎯 Всего монет: {len(coins_list)}")
    try:
        with open(COINS_CACHE_FILE, 'w') as f:
            json.dump({"timestamp": time.time(), "symbols": coins_list}, f)
    except: pass
    return coins_list

