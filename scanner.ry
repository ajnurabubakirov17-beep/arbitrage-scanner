import asyncio
import ccxt.async_support as ccxt
import logging
import time
import json
import websockets

from telegram import InlineKeyboardButton, InlineKeyboardMarkup, Update
from telegram.ext import Application, CommandHandler, CallbackQueryHandler, ContextTypes

# ========= CONFIG =========
TELEGRAM_TOKEN = "YOUR_TOKEN"

EXCHANGES_LIST = ["binance", "bybit", "okx", "kucoin"]
BASE_COINS = ["BTC","ETH","SOL","XRP","BNB","ADA","DOGE","LINK","MATIC","LTC"]

# комиссии бирж
FEES = {
    "binance": 0.001,
    "bybit": 0.001,
    "okx": 0.001,
    "kucoin": 0.001
}

# комиссия сети
NETWORK_FEES = {
    "BTC": 5,
    "ETH": 3,
    "USDT": 1,
    "DEFAULT": 2
}

# ========= STATE =========
USERS = {}
EXCHANGES = {}
BINANCE_WS = {}

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# ========= INIT =========
async def init_exchanges():
    for name in EXCHANGES_LIST:
        try:
            ex = getattr(ccxt, name)({"enableRateLimit": True})
            await ex.load_markets()
            EXCHANGES[name] = ex
            logger.info(f"✅ {name}")
        except Exception as e:
            logger.warning(e)

# ========= WS =========
async def binance_ws():
    stream = "/".join([f"{c.lower()}usdt@bookTicker" for c in BASE_COINS])
    url = f"wss://stream.binance.com:9443/stream?streams={stream}"

    while True:
        try:
            async with websockets.connect(url) as ws:
                async for msg in ws:
                    data = json.loads(msg)["data"]
                    coin = data["s"].replace("USDT","")
                    BINANCE_WS[coin] = {
                        "bid": float(data["b"]),
                        "ask": float(data["a"])
                    }
        except:
            await asyncio.sleep(5)

# ========= ORDERBOOK =========
async def get_orderbook(ex, symbol):
    try:
        return await ex.fetch_order_book(symbol, limit=10)
    except:
        return None

def calc_fill(orderbook, usd, side="buy"):
    total = 0
    coins = 0

    orders = orderbook["asks"] if side=="buy" else orderbook["bids"]

    for price, volume in orders:
        value = price * volume
        if total + value >= usd:
            remain = usd - total
            coins += remain / price
            break
        else:
            total += value
            coins += volume

    return coins

# ========= FETCH =========
async def fetch_prices():
    result = {}

    for name, ex in EXCHANGES.items():
        try:
            for coin in BASE_COINS:
                symbol = f"{coin}/USDT"
                if symbol not in ex.symbols:
                    continue

                ticker = await ex.fetch_ticker(symbol)
                if ticker["quoteVolume"] < 100000:
                    continue

                ob = await get_orderbook(ex, symbol)
                if not ob:
                    continue

                result.setdefault(coin, {})[name] = {
                    "ticker": ticker,
                    "orderbook": ob
                }

        except Exception as e:
            logger.warning(e)

    return result

# ========= ANALYSIS =========
def analyze(data, settings):
    opps = []

    for coin, exchanges in data.items():

        if coin in BINANCE_WS:
            exchanges["binance"] = {
                "ticker": BINANCE_WS[coin],
                "orderbook": None
            }

        if len(exchanges) < 2:
            continue

        for buy_ex, b in exchanges.items():
            for sell_ex, s in exchanges.items():
                if buy_ex == sell_ex:
                    continue

                ask = b["ticker"]["ask"]
                bid = s["ticker"]["bid"]

                if not ask or not bid:
                    continue

                spread = (bid - ask) / ask * 100
                if spread < settings["min_spread"]:
                    continue

                # расчет
                amount = settings["amount"]

                if b["orderbook"] and s["orderbook"]:
                    coins = calc_fill(b["orderbook"], amount, "buy")
                    usd_back = calc_fill(s["orderbook"], amount, "sell") * bid
                else:
                    coins = amount / ask
                    usd_back = coins * bid

                fee = FEES.get(buy_ex,0.001)+FEES.get(sell_ex,0.001)
                net_fee = NETWORK_FEES.get(coin, NETWORK_FEES["DEFAULT"])

                profit = usd_back * (1-fee) - amount - net_fee

                if profit > 0:
                    opps.append({
                        "coin": coin,
                        "buy": buy_ex,
                        "sell": sell_ex,
                        "spread": spread,
                        "profit": profit
                    })

    return sorted(opps, key=lambda x: x["profit"], reverse=True)

# ========= TELEGRAM =========
def keyboard():
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("🚀 Старт", callback_data="start")],
        [InlineKeyboardButton("⛔ Стоп", callback_data="stop")],
        [InlineKeyboardButton("💰 Сумма +", callback_data="amt_up")],
        [InlineKeyboardButton("💰 Сумма -", callback_data="amt_down")],
    ])

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    chat_id = update.effective_chat.id
    USERS[chat_id] = {
        "active": True,
        "last": {},
        "settings": {"min_spread": 0.5, "amount": 300}
    }
    await update.message.reply_text("PRO MAX активен", reply_markup=keyboard())

async def buttons(update: Update, context: ContextTypes.DEFAULT_TYPE):
    q = update.callback_query
    await q.answer()

    user = USERS[q.message.chat_id]

    if q.data == "start":
        user["active"] = True
    elif q.data == "stop":
        user["active"] = False
    elif q.data == "amt_up":
        user["settings"]["amount"] += 100
    elif q.data == "amt_down":
        user["settings"]["amount"] -= 100

    await q.edit_message_text(
        f"Статус: {user['active']}\nСумма: ${user['settings']['amount']}",
        reply_markup=keyboard()
    )

# ========= LOOP =========
async def scanner(app):
    while True:
        try:
            data = await fetch_prices()

            for chat_id, user in USERS.items():
                if not user["active"]:
                    continue

                opps = analyze(data, user["settings"])

                for o in opps[:3]:
                    key = f"{o['coin']}_{o['buy']}_{o['sell']}"
                    now = time.time()

                    if key in user["last"] and now - user["last"][key] < 300:
                        continue

                    user["last"][key] = now

                    msg = (
                        f"🚀 {o['coin']}\n"
                        f"{o['buy']} → {o['sell']}\n"
                        f"Spread: {o['spread']:.2f}%\n"
                        f"Profit: ${o['profit']:.2f}"
                    )

                    await app.bot.send_message(chat_id, msg)

        except Exception as e:
            logger.error(e)

        await asyncio.sleep(5)

# ========= MAIN =========
async def main():
    await init_exchanges()

    app = Application.builder().token(TELEGRAM_TOKEN).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(buttons))

    asyncio.create_task(binance_ws())
    asyncio.create_task(scanner(app))

    await app.initialize()
    await app.start()
    await app.updater.start_polling()
    await app.updater.idle()

if __name__ == "__main__":
    asyncio.run(main())
