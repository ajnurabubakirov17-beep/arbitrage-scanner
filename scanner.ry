def keep_alive():
    """Автопинг каждые 2 минуты"""
    while True:
        try:
            requests.get("http://localhost:8080/health", timeout=5)
            requests.get("http://127.0.0.1:8080/", timeout=5)
            logger.debug("🔄 Автопинг успешен")
        except:
            pass
        time.sleep(120)

# ========= БИРЖИ =========
async def init_exchanges():
    for name in EXCHANGES_LIST:
        try:
            ex = getattr(ccxt, name)({'enableRateLimit': True, 'timeout': 10000})
            await ex.load_markets()
            EXCHANGES[name] = ex
            logger.info(f"✅ {name}")
        except:
            logger.warning(f"⚠️ {name}")

# ========= ПОЛУЧЕНИЕ ЦЕН =========
async def fetch_all_prices():
    result = {}
    for name, ex in EXCHANGES.items():
        try:
            tickers = await ex.fetch_tickers()
            for symbol, ticker in tickers.items():
                if symbol.endswith('/USDT'):
                    coin = symbol.replace('/USDT', '')
                    volume = ticker.get('quoteVolume', 0) or ticker.get('baseVolume', 0)
                    if volume < 10000:
                        continue
                    result[coin] = result.get(coin, {})
                    result[coin][name] = {
                        'bid': ticker.get('bid', 0) or ticker.get('last', 0),
                        'ask': ticker.get('ask', 0) or ticker.get('last', 0),
                        'volume': volume,
                        'last': ticker.get('last', 0)
                    }
        except Exception as e:
            logger.debug(f"{name}: ошибка")
    return result

# ========= АНАЛИЗ С ПРОВЕРКОЙ КОНТРАКТОВ =========
def analyze_all_opportunities(prices, settings):
    opportunities = []
    amount = settings.get('amount', 100)
    min_spread = settings.get('min_spread', 0.3)
    
    if amount < 10:
        amount = 10
    
    for coin, exchanges in prices.items():
        if len(exchanges) < 2:
            continue
        
        exchange_list = list(exchanges.items())
        
        for i, (buy_ex, buy_data) in enumerate(exchange_list):
            for j, (sell_ex, sell_data) in enumerate(exchange_list):
                if buy_ex == sell_ex:
                    continue
                
                ask = buy_data.get('ask', 0)
                bid = sell_data.get('bid', 0)
                
                if ask <= 0 or bid <= 0:
                    continue
                
                # Проверка на аномальные цены
                if ask > 1000000 or bid > 1000000:
                    continue
                
                price_ratio = max(bid, ask) / min(bid, ask)
                if price_ratio > 10:
                    continue
                
                spread = (bid - ask) / ask * 100
                if spread > 50 or spread < min_spread:
                    continue
                
                # ⚠️ ПРОВЕРКА КОНТРАКТОВ
                if not is_same_coin(coin, coin):
                    continue
                
                buy_fee = EXCHANGE_FEES.get(buy_ex, 0.001)
                sell_fee = EXCHANGE_FEES.get(sell_ex, 0.001)
                network_fee = NETWORK_FEES.get(coin, NETWORK_FEES["DEFAULT"])
                transfer_time = TRANSFER_TIME.get(coin, TRANSFER_TIME["DEFAULT"])
                
                # Расчет для нескольких сумм
                profit_results = []
                for test_amount in [10, 50, 100, 200, 500, 1000, 2000, 5000, 10000]:
                    if test_amount < 10:
                        continue
                    
                    coins_bought = test_amount / ask
                    sell_value = coins_bought * bid
                    gross_profit = sell_value - test_amount
                    total_fees = (test_amount * buy_fee) + (sell_value * sell_fee) + network_fee
                    net_profit = gross_profit - total_fees
                    net_profit_pct = (net_profit / test_amount) * 100
                    
                    if net_profit > 0 and net_profit_pct <= 50:
                        profit_results.append({
                            'amount': test_amount,
                            'profit': round(net_profit, 2),
                            'profit_pct': round(net_profit_pct, 2)
                        })
                
                if profit_results:
                    best = max(profit_results, key=lambda x: x['profit'])
                    
                    opportunities.append({
                        'coin': coin,
                        'buy_exchange': buy_ex,
                        'sell_exchange': sell_ex,
                        'buy_price': round(ask, 8),
                        'sell_price': round(bid, 8),
                        'spread': round(spread, 2),
                        'best_amount': best['amount'],
                        'best_profit': best['profit'],
                        'best_profit_pct': best['profit_pct'],
                        'network_fee': network_fee,
                        'transfer_time': transfer_time,
                        'buy_fee': round(buy_fee * 100, 2),
                        'sell_fee': round(sell_fee * 100, 2),
                        'volume': round(min(buy_data.get('volume', 0), sell_data.get('volume', 0)), 0),
                        'last_price': round(buy_data.get('last', ask), 8),
                        'all_profits': profit_results[:5]
                    })
    
    return sorted(opportunities, key=lambda x: x['best_profit'], reverse=True)

def format_opportunity_message(opp):
    """Форматирует сообщение о спреде с полной информацией"""
    msg = f"""
🚀 <b>{opp['coin']}/USDT</b>

📊 <b>СПРЕД:</b> {opp['spread']}%

📈 <b>КУПИТЬ:</b> {opp['buy_exchange'].upper()}
   Цена: <b>${opp['buy_price']}</b>

📉 <b>ПРОДАТЬ:</b> {opp['sell_exchange'].upper()}
   Цена: <b>${opp['sell_price']}</b>

💰 <b>ПРИБЫЛЬ:</b>
• Сумма <b>${opp['best_amount']}</b> → <b>+${opp['best_profit']}</b> ({opp['best_profit_pct']}%)

💸 <b>КОМИССИИ:</b>
• Биржевые: {opp['buy_fee']}% + {opp['sell_fee']}%
• Сетевая: <b>${opp['network_fee']}</b>
• Время перевода: <b>{opp['transfer_time']} мин</b>

📊 <b>ЛИКВИДНОСТЬ:</b>
• Объем 24ч: <b>${int(opp['volume']):,}</b>
• Последняя цена: <b>${opp['last_price']}</b>
"""
    
    if opp.get('all_profits'):
        msg += "\n📋 <b>Прибыль по суммам:</b>\n"
        for p in opp['all_profits'][:3]:
            msg += f"• ${p['amount']:,} → +${p['profit']} ({p['profit_pct']}%)\n"
    
    msg += "\n⚠️ <i>Учитывайте риски: время перевода и ликвидность!</i>"
    return msg

# ========= TELEGRAM БОТ =========
def send_message(chat_id, text, keyboard=None):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    data = {"chat_id": chat_id, "text": text, "parse_mode": "HTML"}
    if keyboard:
        data["reply_markup"] = keyboard
    try:
        requests.post(url, json=data)
    except:
        pass

def show_main_menu(chat_id, is_admin=False):
    user = USERS.get(chat_id, {})
    
    keyboard = {
        "inline_keyboard": [
            [{"text": "🚀 ЗАПУСТИТЬ", "callback_data": "start"},
             {"text": "⏹️ ОСТАНОВИТЬ", "callback_data": "stop"}],
            [{"text": "🔍 ПОКАЗАТЬ ВСЕ СПРЕДЫ", "callback_data": "show_all"}],
            [{"text": "💰 ИЗМЕНИТЬ СУММУ", "callback_data": "change_amount"},
             {"text": "🎯 ИЗМЕНИТЬ MIN СПРЕД", "callback_data": "change_spread"}],
            [{"text": "📊 СТАТУС", "callback_data": "status"},
             {"text": "🏆 ТОП-10 СПРЕДОВ", "callback_data": "top_spreads"}],
            [{"text": "ℹ️ ПОМОЩЬ", "callback_data": "help"}]
        ]
    }
    
    if is_admin:
        keyboard["inline_keyboard"].append([{"text": "👑 АДМИН-ПАНЕЛЬ", "callback_data": "admin_panel"}])
    
    text = f"""
🤖 <b>ПРОФЕССИОНАЛЬНЫЙ АРБИТРАЖНЫЙ СКАНЕР</b>

📊 <b>ДАННЫЕ СИСТЕМЫ:</b>
• 🪙 Монет: <b>{len(TOP_COINS)}</b> (с бирж)
• 🏦 Бирж: <b>{len(EXCHANGES)}</b> активных

⚙️ <b>ВАШИ НАСТРОЙКИ:</b>
• 💰 Сумма: <b>${user.get('amount', 100)}</b> (мин 10$)
• 🎯 Min спред: <b>{user.get('min_spread', 0.3)}%</b>
• 🔔 Уведомления: <b>{'ВКЛЮЧЕНЫ ✅' if user.get('active', False) else 'ВЫКЛЮЧЕНЫ ⏹️'}</b>

👇 <b>ВЫБЕРИТЕ ДЕЙСТВИЕ:</b>
"""
