        warning = "⚠️ НЕТ ПОДПИСКИ! Оформите в 💎 ПОДПИСКА\n\n"
    text = f"{warning}🤖 <b>АРБИТРАЖНЫЙ СКАНЕР</b>\n\n📊 Монет: {len(TOP_COINS)}\n🏦 Бирж: {len(EXCHANGES)}\n⚡ WebSocket: Binance (реальное время)\n\n⚙️ <b>НАСТРОЙКИ:</b>\n💰 Сумма: ${user.get('amount', 100)}\n🎯 Min спред: {user.get('min_spread', 0.3)}%\n⭐ Избранное: {', '.join(favorites[:5]) if favorites else 'нет'}\n\n💎 <b>ПОДПИСКА:</b>\n{sub_status}\n\n👇 ВЫБЕРИТЕ ДЕЙСТВИЕ:"
    send_message(chat_id, text, json.dumps(keyboard))

def show_favorites_menu(chat_id):
    favorites = get_user_favorites(chat_id)
    top_coins = TOP_COINS[:30] if TOP_COINS else ["BTC", "ETH", "SOL", "BNB", "XRP"]
    keyboard = {"inline_keyboard": []}
    for coin in top_coins:
        status = "✅" if coin in favorites else "❌"
        keyboard["inline_keyboard"].append([{"text": f"{status} {coin}", "callback_data": f"fav_{coin}"}])
    keyboard["inline_keyboard"].append([{"text": "🔙 НАЗАД", "callback_data": "back"}])
    send_message(chat_id, f"⭐ ИЗБРАННЫЕ\n\nТекущие: {', '.join(favorites[:10]) or 'нет'}", json.dumps(keyboard))

def show_history(chat_id):
    top_spreads = get_top_spreads_history(10)
    if not top_spreads:
        send_message(chat_id, "📜 История пуста")
        return
    text = "📜 ТОП-10 СПРЕДОВ\n\n"
    for i, (coin, buy_ex, sell_ex, spread, profit, amount, date) in enumerate(top_spreads, 1):
        text += f"{i}. {coin} | {buy_ex}→{sell_ex} | {spread:.2f}% | +${profit:.2f} | {date}\n"
    send_message(chat_id, text)

def show_amount_keyboard(chat_id):
    keyboard = {"inline_keyboard": [[{"text": f"${a}", "callback_data": f"amt_{a}"} for a in [10,50,100,500,1000,5000,10000]], [{"text":"🔙 НАЗАД","callback_data":"back"}]]}
    send_message(chat_id, "💰 ВЫБЕРИТЕ СУММУ:", json.dumps(keyboard))

def show_spread_keyboard(chat_id):
    keyboard = {"inline_keyboard": [[{"text": f"{s}%", "callback_data": f"spread_{int(s*100):02d}"} for s in [0.1,0.2,0.3,0.5,1.0,2.0]], [{"text":"🔙 НАЗАД","callback_data":"back"}]]}
    send_message(chat_id, "🎯 ВЫБЕРИТЕ MIN СПРЕД:", json.dumps(keyboard))

def show_subscription_menu(chat_id):
    text = "💎 ВЫБЕРИТЕ ТАРИФ\n\n"
    keyboard = []
    for plan_id, plan in PLANS.items():
        text += f"• {plan['name']} — ${plan['price']}\n"
        keyboard.append([{"text": f"💳 {plan['name']} — ${plan['price']}", "callback_data": f"plan_{plan_id}"}])
    keyboard.append([{"text": "🔙 НАЗАД", "callback_data": "back"}])
    send_message(chat_id, text, json.dumps({"inline_keyboard": keyboard}))

def show_confirm_payment(chat_id, plan_id):
    plan = PLANS.get(plan_id)
    if not plan:
        return
    text = f"💳 ОПЛАТА\n\nТариф: {plan['name']}\nСумма: ${plan['price']} USDT\n\nОтправьте {plan['price']} USDT на:\n<code>TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t</code> (TRC-20)\n\nПосле оплаты: /confirm {plan_id} TXID"
    send_message(chat_id, text)

def confirm_payment(chat_id, plan_id, txid):
    plan = PLANS.get(plan_id)
    if not plan:
        return False
    paid_until = int(time.time()) + (plan["days"] * 86400)
    if save_subscription(chat_id, plan_id, paid_until, plan["price"], txid):
        send_message(chat_id, f"✅ {plan['name']} активирована до {datetime.fromtimestamp(paid_until).strftime('%d.%m.%Y')}")
        ref_info = get_user_referral_info(chat_id)
        if ref_info.get("referred_by"):
            bonus = plan["price"] * 0.2
            add_referral_earnings(ref_info["referred_by"], bonus)
            send_message(ref_info["referred_by"], f"🎉 Реферал оформил подписку! +${bonus:.2f}")
        return True
    return False

def show_referral_menu(chat_id):
    ref_info = get_user_referral_info(chat_id)
    link = generate_referral_link(chat_id)
    text = f"🎁 РЕФЕРАЛЫ\n\n🔗 {link}\n\n👥 Приглашено: {len(ref_info.get('referrals', []))}\n💰 Заработано: ${ref_info.get('earnings', 0):.2f}\n\n💎 Вы получаете 20% от платежей!"
    keyboard = {"inline_keyboard": [[{"text": "📋 СКОПИРОВАТЬ", "callback_data": "copy_link"}], [{"text": "🔙 НАЗАД", "callback_data": "back"}]]}
    send_message(chat_id, text, json.dumps(keyboard))

def show_admin_panel(chat_id):
    keyboard = {"inline_keyboard": [[{"text":"📊 СТАТИСТИКА","callback_data":"admin_stats"}],[{"text":"👥 ПОЛЬЗОВАТЕЛИ","callback_data":"admin_users"}],[{"text":"📋 ПЛАТЕЖИ","callback_data":"admin_payments"}],[{"text":"🔙 НАЗАД","callback_data":"back"}]]}
    send_message(chat_id, "👑 АДМИН-ПАНЕЛЬ", json.dumps(keyboard))

def run_bot():
    global last_update_id
    while True:
        try:
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates"
            resp = requests.get(url, params={"offset": last_update_id + 1, "timeout": 30})
            data = resp.json()
            if not data.get("ok"):
                continue
            for update in data.get("result", []):
                last_update_id = update["update_id"] + 1
                msg = update.get("message")
                if msg:
                    chat_id = msg["chat"]["id"]
                    is_admin = (chat_id == ADMIN_ID)
                    text = msg.get("text", "")
                    if chat_id not in USERS:
                        USERS[chat_id] = {"active": False, "amount": 100, "min_spread": 0.3, "last_alerts": {}}
                        save_user_to_db(chat_id)
                    if text == "/start":
                        if "ref_" in text:
                            try:
                                referrer_id = int(text.split("ref_")[1])
                                if referrer_id != chat_id:
                                    add_referral(chat_id, referrer_id)
                                    send_message(chat_id, "🎉 Вы по реферальной ссылке!")
                                    send_message(referrer_id, "🎉 Новый реферал!")
                            except: pass
                        show_main_menu(chat_id, is_admin)
                    elif text.startswith("/confirm"):
                        parts = text.split()
                        if len(parts) >= 3:
                            confirm_payment(chat_id, parts[1], parts[2])
                callback = update.get("callback_query")
                if callback:
                    chat_id = callback["message"]["chat"]["id"]
                    data_cb = callback["data"]
                    is_admin = (chat_id == ADMIN_ID)
                    if chat_id not in USERS:
                        USERS[chat_id] = {"active": False, "amount": 100, "min_spread": 0.3, "last_alerts": {}}
                    user = USERS[chat_id]
                    try:
                        requests.post(f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/answerCallbackQuery", json={"callback_query_id": callback["id"]})
                    except: pass
                    if data_cb == "start":
                        if check_subscription(chat_id):
                            user["active"] = True
                            send_message(chat_id, "✅ Уведомления ВКЛЮЧЕНЫ!")
                        else:
                            send_message(chat_id, "❌ Оформите подписку!")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "stop":
                        user["active"] = False
                        send_message(chat_id, "⏹️ Уведомления ВЫКЛЮЧЕНЫ!")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "show_all":
                        if not check_subscription(chat_id) and not is_admin:
                            send_message(chat_id, "❌ Оформите подписку!")
                            show_main_menu(chat_id, is_admin)
                            continue
                        send_message(chat_id, "🔍 ИЩУ СПРЕДЫ...")
                        if last_prices:
                            opps = analyze_all_opportunities(last_prices, {**user, "favorites": get_user_favorites(chat_id)})
                            if opps:
                                for opp in opps[:10]:
                                    send_message(chat_id, format_opportunity_message(opp))
                                send_message(chat_id, f"📊 Найдено {len(opps)} спредов")
                            else:
                                send_message(chat_id, "😴 Спредов нет")
                        else:
                            send_message(chat_id, "🔄 Данные загружаются...")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "favorites_menu":
                        show_favorites_menu(chat_id)
                    elif data_cb.startswith("fav_"):
                        coin = data_cb.replace("fav_", "")
                        favs = get_user_favorites(chat_id)
                        if coin in favs:
                            favs.remove(coin)
                        else:
                            favs.append(coin)
                        update_user_favorites(chat_id, favs)
                        show_favorites_menu(chat_id)
                    elif data_cb == "change_amount":
                        show_amount_keyboard(chat_id)
                    elif data_cb.startswith("amt_"):
                        user["amount"] = int(data_cb.replace("amt_", ""))
                        send_message(chat_id, f"✅ Сумма: ${user['amount']}")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "change_spread":
                        show_spread_keyboard(chat_id)
                    elif data_cb.startswith("spread_"):
                        user["min_spread"] = float(data_cb.replace("spread_", "")) / 100
                        send_message(chat_id, f"✅ Min спред: {user['min_spread']}%")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "top_spreads":
                        if not check_subscription(chat_id) and not is_admin:
                            send_message(chat_id, "❌ Оформите подписку!")
                            show_main_menu(chat_id, is_admin)
                            continue
                        if last_prices:
                            opps = analyze_all_opportunities(last_prices, {**user, "favorites": get_user_favorites(chat_id)})
                            if opps:
                                text = "🏆 ТОП-10\n\n"
                                for i, o in enumerate(opps[:10], 1):
                                    text += f"{i}. {o['coin']} | {o['buy_exchange']}→{o['sell_exchange']} | {o['spread']}% | +${o['best_profit']}\n"
                                send_message(chat_id, text)
                            else:
                                send_message(chat_id, "😴 Спредов нет")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "chart":
                        if not check_subscription(chat_id) and not is_admin:
                            send_message(chat_id, "❌ Оформите подписку!")
                            show_main_menu(chat_id, is_admin)
                            continue
                        buf = generate_spread_chart()
                        if buf:
                            requests.post(f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendPhoto", files={'photo': ('chart.png', buf)}, data={'chat_id': chat_id, 'caption': '📈 График спредов'})
                        else:
                            send_message(chat_id, "📊 Недостаточно данных")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "history":
                        if not check_subscription(chat_id) and not is_admin:
                            send_message(chat_id, "❌ Оформите подписку!")
                            show_main_menu(chat_id, is_admin)
                            continue
                        show_history(chat_id)
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "referral_menu":
                        show_referral_menu(chat_id)
                    elif data_cb == "copy_link":
                        send_message(chat_id, f"🔗 {generate_referral_link(chat_id)}")
                        show_referral_menu(chat_id)
                    elif data_cb == "subscription_menu":
                        show_subscription_menu(chat_id)
                    elif data_cb.startswith("plan_"):
                        show_confirm_payment(chat_id, data_cb.replace("plan_", ""))
                    elif data_cb == "status":
                        if not check_subscription(chat_id) and not is_admin:
                            send_message(chat_id, "❌ Оформите подписку!")
                            show_main_menu(chat_id, is_admin)
                            continue
                        favs = get_user_favorites(chat_id)
                        text = f"📊 СТАТУС\n\nАктивен: {'✅' if user['active'] else '⏹️'}\nСумма: ${user['amount']}\nMin спред: {user['min_spread']}%\nМонет: {len(TOP_COINS)}\nБирж: {len(EXCHANGES)}\n⭐ Избранное: {', '.join(favs[:5]) or 'нет'}"
                        send_message(chat_id, text)
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "admin_panel" and is_admin:
                        show_admin_panel(chat_id)
                    elif data_cb == "admin_stats" and is_admin:
                        active = sum(1 for u in USERS.values() if u.get("active"))
                        sub_count = 0
                        try:
                            conn = sqlite3.connect(DB_FILE)
                            c = conn.cursor()
                            c.execute("SELECT COUNT(*) FROM subscriptions WHERE paid_until > ?", (int(time.time()),))
                            sub_count = c.fetchone()[0]
                            conn.close()
                        except: pass
                        send_message(chat_id, f"📊 СТАТИСТИКА\n\n👥 Пользователей: {len(USERS)}\n🟢 Активных: {active}\n💎 Подписок: {sub_count}\n🪙 Монет: {len(TOP_COINS)}\n🏦 Бирж: {len(EXCHANGES)}")
                        show_admin_panel(chat_id)
                    elif data_cb == "admin_users" and is_admin:
                        text = "👥 ПОЛЬЗОВАТЕЛИ\n\n"
                        for uid, u in list(USERS.items())[:20]:
                            sub = get_user_subscription(uid)
                            sub_status = "💎" if sub and sub["paid_until"] > time.time() else "❌"
                            text += f"• {uid}: {sub_status} {'✅' if u.get('active') else '⏹️'}\n"
                        send_message(chat_id, text)
                        show_admin_panel(chat_id)
                    elif data_cb == "admin_payments" and is_admin:
                        try:
                            conn = sqlite3.connect(DB_FILE)
                            c = conn.cursor()
                            c.execute("SELECT chat_id, plan, amount, payment_date FROM subscriptions ORDER BY payment_date DESC LIMIT 10")
                            payments = c.fetchall()
                            conn.close()
                            text = "📋 ПОСЛЕДНИЕ ПЛАТЕЖИ\n\n"
                            for p in payments:
                                text += f"• {p[0]} | {p[1]} | ${p[2]} | {datetime.fromtimestamp(p[3]).strftime('%d.%m')}\n"
                            send_message(chat_id, text)
                        except: pass
                        show_admin_panel(chat_id)
                    elif data_cb == "help":
                        send_message(chat_id, "ℹ️ ПОМОЩЬ\n\n🚀 ЗАПУСТИТЬ — автоуведомления\n🔍 ПОКАЗАТЬ СПРЕДЫ — ручной поиск\n⭐ ИЗБРАННЫЕ — выбор монет\n💰 СУММА — от $10\n🎯 MIN СПРЕД — порог\n🏆 ТОП-10 — лучшие\n📈 ГРАФИК — визуализация\n📜 ИСТОРИЯ — все спреды\n🎁 РЕФЕРАЛЫ — 20%\n💎 ПОДПИСКА — тарифы")
                        show_main_menu(chat_id, is_admin)
                    elif data_cb == "back":
                        show_main_menu(chat_id, is_admin)
                    time.sleep(0.05)
        except Exception as e:
            logger.error(f"Ошибка: {e}")
            time.sleep(1)

# ========= ОСНОВНОЙ СКАНЕР =========
async def main_scanner():
    global last_prices, TOP_COINS
    TOP_COINS = await load_coins_from_exchanges()
    logger.info(f"🎯 ЗАГРУЖЕНО {len(TOP_COINS)} МОНЕТ")
    while True:
        try:
            prices = await fetch_all_prices()
            last_prices = prices
            for chat_id, user in USERS.items():
                if user.get("active") and check_subscription(chat_id):
                    opps = analyze_all_opportunities(prices, {**user, "favorites": get_user_favorites(chat_id)})
                    for opp in opps[:3]:
                        key = f"{opp['coin']}_{opp['buy_exchange']}_{opp['sell_exchange']}"
                        now = time.time()
                        if key in user["last_alerts"] and now - user["last_alerts"][key] < 300:
                            continue
                        user["last_alerts"][key] = now
                        send_message(chat_id, format_opportunity_message(opp))
            logger.info("✅ Сканирование завершено")
        except Exception as e:
            logger.error(f"Ошибка сканера: {e}")
        await asyncio.sleep(15)

# ========= ЗАПУСК =========
async def main():
    init_db()
    await init_exchanges()
    asyncio.create_task(start_websockets())
    threading.Thread(target=run_web, daemon=True).start()
    threading.Thread(target=keep_alive, daemon=True).start()
    threading.Thread(target=run_bot, daemon=True).start()
    logger.info("="*50)
    logger.info("🚀 АРБИТРАЖНЫЙ СКАНЕР С WEBSOCKET")
    logger.info(f"🏦 Бирж: {len(EXCHANGES)}")
    logger.info("⚡ WebSocket: Binance (реальное время)")
    logger.info("="*50)
    await main_scanner()

if __name__ == "__main__":
    asyncio.run(main())
