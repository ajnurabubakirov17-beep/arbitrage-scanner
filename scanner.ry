# ========== ЗАГРУЗКА МОНЕТ ИЗ CCXT ==========
COINS_CACHE_FILE = "coins_cache.json"

def get_coins():
    """Загружает список монет из кэша или собирает с бирж"""
    
    # Пробуем загрузить из кэша
    if os.path.exists(COINS_CACHE_FILE):
        try:
            with open(COINS_CACHE_FILE, 'r') as f:
                data = json.load(f)
                if time.time() - data.get("timestamp", 0) < 86400:  # 24 часа
                    coins = data.get("symbols", [])
                    if len(coins) > 50:
                        logger.info(f"📦 Загружено {len(coins)} монет из кэша")
                        logger.info(f"📊 Первые 10: {coins[:10]}")
                        return coins
        except:
            pass
    
    logger.info("🔄 Сбор монет с бирж CCXT...")
    all_coins = set()
    
    # Список бирж для сбора монет
    exchange_names = [
        'binance', 'okx', 'bybit', 'kucoin', 'gateio', 'huobi', 'mexc',
        'kraken', 'bitfinex', 'poloniex', 'hitbtc', 'whitebit', 'bitmart',
        'lbank', 'coinex', 'phemex', 'cryptocom', 'gemini', 'bithumb', 'upbit'
    ]
    
    for name in exchange_names:
        try:
            exchange_class = getattr(ccxt, name)
            exchange = exchange_class({
                'enableRateLimit': True,
                'timeout': 10000
            })
            
            markets = exchange.load_markets()
            count = 0
            
            for market in markets:
                if '/USDT' in market.upper():
                    symbol = market.upper().replace('/USDT', '').split(':')[0]
                    if len(symbol) <= 8 and symbol.isalnum():
                        all_coins.add(symbol)
                        count += 1
            
            logger.info(f"  ✅ {name}: +{count} монет")
            time.sleep(0.3)
            
        except Exception as e:
            logger.debug(f"  ⚠️ {name}: пропущена")
    
    coins_list = sorted(list(all_coins))
    
    # Добавляем базовые монеты если мало
    if len(coins_list) < 100:
        basic = ["BTC", "ETH", "SOL", "BNB", "XRP", "DOGE", "ADA", "AVAX", "DOT", "LINK"]
        for coin in basic:
            if coin not in coins_list:
                coins_list.append(coin)
        logger.info(f"➕ Добавлено {len(basic)} базовых монет")
    
    # Сохраняем кэш
    try:
        with open(COINS_CACHE_FILE, 'w') as f:
            json.dump({
                "timestamp": time.time(),
                "symbols": coins_list
            }, f)
        logger.info(f"💾 Сохранено {len(coins_list)} монет в кэш")
    except:
        pass
    
    return coins_list

