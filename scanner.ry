def check_contract(symbol):
    if symbol in ["BTC", "ETH", "SOL", "BNB", "XRP", "TRX", "DOGE", "ADA"]:
        return "✅ Нативный токен (без контракта)"
    if symbol in TOKEN_CONTRACTS:
        return "✅ Контракт проверен (ликвиден)"
    return "⚠️ Контракт не проверен (риск)"

# ========== ПОЛУЧЕНИЕ ЦЕН ЧЕРЕЗ CCXT ==========
async def fetch_exchange_ccxt(exchange_name, exchange):
    """
    Получает цены с одной биржи через CCXT
    """
    try:
        tickers = exchange.fetch_tickers()
        
        result = {}
        for symbol, ticker in tickers.items():
            if symbol.endswith('/USDT'):
                coin = symbol.replace('/USDT', '')
                
                ask = ticker.get('ask') or ticker.get('last')
                bid = ticker.get('bid') or ticker.get('last')
                volume = ticker.get('quoteVolume') or ticker.get('baseVolume', 0)
                
                if ask and bid and volume > MIN_VOLUME_24H:
                    result[coin] = {
                        'ask': float(ask),
                        'bid': float(bid),
                        'volume': float(volume),
                        'spread': ((bid - ask) / ask) * 100 if ask else 0
                    }
        
        return result
        
    except Exception as e:
        logger.debug(f"{exchange_name}: ошибка - {e}")
        return {}

async def get_all_prices():
    """
    Асинхронно собирает цены со всех бирж
    """
    all_prices = {sym: {} for sym in SYMBOLS}
    
    tasks = [fetch_exchange_ccxt(name, exchange) for name, exchange in EXCHANGES.items()]
    results = await asyncio.gather(*tasks)
    
    for i, name in enumerate(EXCHANGES.keys()):
        for coin, prices in results[i].items():
            if coin in all_prices:
                all_prices[coin][name] = prices
    
    return all_prices

# ========== АНАЛИЗ СПРЕДА ==========
def analyze_opportunity(buy_price, sell_price, buy_exchange, sell_exchange, symbol, volume):
    """
    Анализирует арбитражную возможность
    """
    buy_fee = EXCHANGE_FEES.get(buy_exchange, 0.001)
    sell_fee = EXCHANGE_FEES.get(sell_exchange, 0.001)
    net_info = TRANSFER_NETWORKS.get(symbol, TRANSFER_NETWORKS["DEFAULT"])
    transfer_fee = net_info["fee_usd"]
    min_amount = net_info.get("min_amount", 10)
    contract = check_contract(symbol)
    
    results = []
    for amount in TRADE_AMOUNTS:
        if amount < min_amount:
            continue
        
        # Проверяем, что сумма не превышает ликвидность
        max_coins = volume / sell_price if sell_price > 0 else 0
        max_amount = max_coins * buy_price
        if amount > max_amount * 0.1:  # Не берем больше 10% от объема
            continue
        
        buy_cost = amount
        coins = (amount - transfer_fee) / buy_price if transfer_fee < amount else amount / buy_price
        sell_value = coins * sell_price
        net_profit = sell_value * (1 - sell_fee) - buy_cost * (1 + buy_fee)
        net_profit_percent = (net_profit / amount) * 100
        
        if net_profit > 0:
            results.append({
                "amount": amount,
                "profit": net_profit,
                "profit_percent": net_profit_percent
            })
    
    if not results:
        return None
    
    best = max(results, key=lambda x: x["profit"])
    spread = ((sell_price - buy_price) / buy_price) * 100
    
    return {
        "spread": spread,
        "best_amount": best["amount"],
        "best_profit": best["profit"],
        "best_percent": best["profit_percent"],
        "transfer_fee": transfer_fee,
        "transfer_time": net_info["time_min"],
        "network": net_info["network"],
        "buy_fee": buy_fee * 100,
        "sell_fee": sell_fee * 100,
        "contract": contract,
        "volume": volume,
        "results": results[:5]
    }

def find_opportunities(all_prices):
    """
    Находит все арбитражные возможности
    """
    opportunities = []
    
    for sym in all_prices.keys():
        prices = all_prices[sym]
        if len(prices) >= 2:
            for buy_ex, buy_data in prices.items():
                for sell_ex, sell_data in prices.items():
                    if buy_ex == sell_ex:
                        continue
                    
                    spread = ((sell_data["bid"] - buy_data["ask"]) / buy_data["ask"]) * 100
                    
                    if spread > MIN_PROFIT:
                        analysis = analyze_opportunity(
                            buy_data["ask"], 
                            sell_data["bid"], 
                            buy_ex, 
                            sell_ex, 
                            sym,
                            min(buy_data.get("volume", 0), sell_data.get("volume", 0))
                        )
                        if analysis:
                            opportunities.append({
                                "symbol": sym,
                                "buy_exchange": buy_ex,
                                "sell_exchange": sell_ex,
                                "buy_price": buy_data["ask"],
                                "sell_price": sell_data["bid"],
                                "volume": min(buy_data.get("volume", 0), sell_data.get("volume", 0)),
                                "analysis": analysis
                            })
    
    return sorted(opportunities, key=lambda x: x["analysis"]["best_profit"], reverse=True)

