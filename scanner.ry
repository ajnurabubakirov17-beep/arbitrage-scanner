def keep_alive():
    """Пинг сам себя каждые 5 минут, чтобы Render не усыпил"""
    while True:
        try:
            response = requests.get("http://localhost:8080/health", timeout=5)
            if response.status_code == 200:
                logger.debug("🔄 Автопинг: сервер активен")
            else:
                logger.warning("⚠️ Автопинг: странный ответ")
        except Exception as e:
            logger.warning(f"⚠️ Автопинг: ошибка - {e}")
        time.sleep(300)  # 5 минут

# ========= ИНИЦИАЛИЗАЦИЯ БИРЖ =========
async def init_exchanges():
    for name in EXCHANGES_LIST:
        try:
            ex = getattr(ccxt, name)({
                "enableRateLimit": True,
                "timeout": 30000,
                "options": {"defaultType": "spot"}
            })
            await ex.load_markets()
            EXCHANGES[name] = ex
            logger.info(f"✅ {name}")
        except Exception as e:
            logger.warning(f"⚠️ {name}: {str(e)[:30]}")
    logger.info(f"🏦 Активных бирж: {len(EXCHANGES)} из {len(EXCHANGES_LIST)}")

# ========= ПОЛУЧЕНИЕ ЦЕН =========
async def fetch_all_prices():
    """Получает цены со всех бирж"""
    result = {}
    
    for name, ex in EXCHANGES.items():
        try:
            for coin in BASE_COINS:
                symbol = f"{coin}/USDT"
                if symbol not in ex.symbols:
                    continue
                
                ticker = await ex.fetch_ticker(symbol)
                volume = ticker.get("quoteVolume", 0) or ticker.get("baseVolume", 0)
                if volume < 100000:
                    continue
                
                result.setdefault(coin, {})[name] = {
                    "bid": ticker.get("bid", 0),
                    "ask": ticker.get("ask", 0),
                    "last": ticker.get("last", 0),
                    "volume": volume
                }
        except Exception as e:
            logger.debug(f"{name}: ошибка")
    
    return result

# ========= АНАЛИЗ АРБИТРАЖА =========
def analyze_arbitrage(data, settings):
    opportunities = []
    min_spread = settings.get("min_spread", 0.3)
    amount = settings.get("amount", 500)
    
    for coin, exchanges in data.items():
        if len(exchanges) < 2:
            continue
        
        network_fee = NETWORK_FEES.get(coin, NETWORK_FEES["DEFAULT"])
        transfer_time = TRANSFER_TIME.get(coin, TRANSFER_TIME["DEFAULT"])
        
        for buy_ex, buy_data in exchanges.items():
            for sell_ex, sell_data in exchanges.items():
                if buy_ex == sell_ex:
                    continue
                
                ask = buy_data.get("ask") or buy_data.get("last")
                bid = sell_data.get("bid") or sell_data.get("last")
                
                if not ask or not bid or ask <= 0 or bid <= 0:
                    continue
                
                spread = ((bid - ask) / ask) * 100
                if spread < min_spread:
                    continue
                
                buy_fee = FEES.get(buy_ex, 0.001)
                sell_fee = FEES.get(sell_ex, 0.001)
                
                coins_bought = amount / ask
                sell_value = coins_bought * bid
                gross_profit = sell_value - amount
                total_fees = (amount * buy_fee) + (sell_value * sell_fee) + network_fee
                net_profit = gross_profit - total_fees
                net_profit_percent = (net_profit / amount) * 100
                
                if net_profit > 0:
                    opportunities.append({
                        "coin": coin,
                        "buy_exchange": buy_ex,
                        "sell_exchange": sell_ex,
                        "buy_price": ask,
                        "sell_price": bid,
                        "spread": spread,
                        "net_profit": net_profit,
                        "profit_percent": net_profit_percent,
                        "network_fee": network_fee,
                        "transfer_time": transfer_time,
                        "buy_fee": buy_fee * 100,
                        "sell_fee": sell_fee * 100,
                        "volume": min(buy_data.get("volume", 0), sell_data.get("volume", 0))
                    })
    
    return sorted(opportunities, key=lambda x: x["net_profit"], reverse=True)

# ========= ФОНДОВОЕ СКАНИРОВАНИЕ (только сохранение данных) =========
async def background_scanner():
    """Фоновое сканирование - только сохраняет данные, не отправляет уведомления"""
    global last_scan_data
    logger.info("🚀 ФОНОВЫЙ СКАНЕР ЗАПУЩЕН (только сбор данных)")
    
    while True:
        try:
            start_time = time.time()
            
            # Получаем цены
            prices = await fetch_all_prices()
            
            # Сохраняем данные для всех пользователей (анализ будет по запросу)
            last_scan_data = {
                "prices": prices,
                "timestamp": time.time()
            }
            
            elapsed = time.time() - start_time
            logger.info(f"⚡ Данные обновлены за {elapsed:.1f} сек")
            
        except Exception as e:
            logger.error(f"❌ Ошибка в сканере: {e}")
        
        await asyncio.sleep(10)

