async def button_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    chat_id = query.message.chat_id
    data = query.data
    
    if chat_id not in user_scanners:
        user_scanners[chat_id] = {
            "active": False,
            "min_profit": 0.1,
            "last_alerts": {}
        }
    
    user = user_scanners[chat_id]
    
    if data == "start":
        user["active"] = True
        await query.edit_message_text(
            "✅ <b>Сканер запущен!</b>\n\nЯ буду присылать уведомления при нахождении арбитражных возможностей.",
            parse_mode='HTML',
            reply_markup=get_main_keyboard()
        )
        
    elif data == "stop":
        user["active"] = False
        await query.edit_message_text(
            "⏹️ <b>Сканер остановлен.</b>\n\nЧтобы возобновить, нажмите 'Запустить'.",
            parse_mode='HTML',
            reply_markup=get_main_keyboard()
        )
        
    elif data == "status":
        status_text = f"""
📊 <b>Статус сканера</b>

🟢 Состояние: {'Активен ✅' if user['active'] else 'Остановлен ⏹️'}
💰 MIN PROFIT: {user['min_profit']}%
🏦 Активных бирж: {len(EXCHANGES)}
📈 Монет в базе: {len(SYMBOLS)}
🎯 Цель: арбитраж между биржами

⚡ Интервал сканирования: {SCAN_INTERVAL} сек
💵 Мин. объем монеты: ${MIN_VOLUME_24H:,.0f}
        """
        await query.edit_message_text(
            status_text,
            parse_mode='HTML',
            reply_markup=get_main_keyboard()
        )
        
    elif data == "settings":
        await query.edit_message_text(
            "⚙️ <b>Настройки сканера</b>\n\nВыберите минимальный процент прибыли:",
            parse_mode='HTML',
            reply_markup=get_settings_keyboard()
        )
        
    elif data == "top_spreads":
        await query.edit_message_text(
            "📊 <b>Топ спредов сейчас</b>\n\nСканирую... подождите несколько секунд...",
            parse_mode='HTML',
            reply_markup=get_main_keyboard()
        )
        
        # Показываем топ спредов
        prices = await get_all_prices()
        opps = find_opportunities(prices)
        
        if opps:
            top_msg = "🔥 <b>ТОП-5 АРБИТРАЖНЫХ ВОЗМОЖНОСТЕЙ</b>\n\n"
            for i, opp in enumerate(opps[:5], 1):
                a = opp["analysis"]
                top_msg += f"{i}. <b>{opp['symbol']}/USDT</b>\n"
                top_msg += f"   📊 Спред: {a['spread']:.2f}%\n"
                top_msg += f"   💰 Прибыль: ${a['best_profit']:.2f} (с ${a['best_amount']:,.0f})\n"
                top_msg += f"   📈 {opp['buy_exchange'].upper()} → {opp['sell_exchange'].upper()}\n\n"
            
            await query.edit_message_text(
                top_msg,
                parse_mode='HTML',
                reply_markup=get_main_keyboard()
            )
        else:
            await query.edit_message_text(
                "😴 Сейчас нет активных спредов. Попробуйте позже!",
                parse_mode='HTML',
                reply_markup=get_main_keyboard()
            )
        
    elif data.startswith("set_profit_"):
        profit_value = float(data.replace("set_profit_", "")) / 100
        user["min_profit"] = profit_value
        
        # Обновляем глобальный MIN_PROFIT для этого пользователя
        global MIN_PROFIT
        MIN_PROFIT = min(MIN_PROFIT, profit_value)
        
        await query.edit_message_text(
            f"✅ <b>MIN PROFIT установлен на {profit_value}%</b>\n\nСканер будет присылать уведомления при спреде выше {profit_value}%.",
            parse_mode='HTML',
            reply_markup=get_main_keyboard()
        )
        
    elif data == "back":
        await query.edit_message_text(
            "Главное меню:",
            parse_mode='HTML',
            reply_markup=get_main_keyboard()
        )

async def send_telegram_alert(chat_id, opp, context):
    user = user_scanners.get(chat_id)
    if not user or not user.get("active", False):
        return
    
    a = opp["analysis"]
    
    msg = f"""
🚀 <b>СПРЕД НАЙДЕН!</b>

💰 <b>{opp['symbol']}/USDT</b>
📊 Спред: {a['spread']:.3f}%

📈 КУПИТЬ: {opp['buy_exchange'].upper()} | ${opp['buy_price']:,.6f}
📉 ПРОДАТЬ: {opp['sell_exchange'].upper()} | ${opp['sell_price']:,.6f}
📊 Объем 24ч: ${opp['volume']:,.0f}

💸 Комиссии: {a['buy_fee']:.2f}% + {a['sell_fee']:.2f}%
🌐 Перевод: {a['network']} | ${a['transfer_fee']:.2f} | {a['transfer_time']} мин
🛡️ {a['contract']}

✨ <b>ЛУЧШАЯ СУММА: ${a['best_amount']:,.0f}</b>
💰 Прибыль: ${a['best_profit']:.2f} ({a['best_percent']:.2f}%)

💵 ПРИБЫЛЬ ПО СУММАМ:
"""
    
    for r in a["results"][:5]:
        msg += f"• ${r['amount']:,} → +${r['profit']:.2f} ({r['profit_percent']:.2f}%)\n"
    
    msg += "\n⚠️ Учитывайте риски: время перевода, ликвидность, комиссии сети!"
    
    try:
        await context.bot.send_message(chat_id=chat_id, text=msg, parse_mode='HTML')
    except Exception as e:
        logger.error(f"Ошибка отправки в Telegram: {e}")

async def send_alert_to_all(opp):
    """Отправляет уведомление всем активным пользователям"""
    for chat_id, user in user_scanners.items():
        if user.get("active", False):
            if telegram_app:
                await send_telegram_alert(chat_id, opp, telegram_app)

telegram_app = None

def run_telegram_bot():
    """Запускает простой Telegram бот без внешних библиотек"""
    import requests as tg_requests
    import time as tg_time
    
    last_update_id = 0
    
    while True:
        try:
            # Получаем обновления
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/getUpdates"
            resp = tg_requests.get(url, params={"offset": last_update_id + 1, "timeout": 30})
            data = resp.json()
            
            if not data.get("ok"):
                continue
                
            updates = data.get("result", [])
            
            for update in updates:
                last_update_id = update["update_id"]
                
                # Обработка сообщений
                message = update.get("message")
                if message:
                    chat_id = message["chat"]["id"]
                    text = message.get("text", "")
                    
                    if text == "/start":
                        welcome = f"""🤖 <b>Арбитражный сканер</b>

📊 Монет: {len(SYMBOLS)}
🏦 Бирж: {len(EXCHANGES)}
💰 MIN PROFIT: {MIN_PROFIT}%

<b>Команды:</b>
/start - Показать это сообщение
/status - Статус сканера
/on - Включить уведомления
/off - Выключить уведомления"""
                        
                        tg_requests.post(
                            f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
                            json={"chat_id": chat_id, "text": welcome, "parse_mode": "HTML"}
                        )
                    
                    elif text == "/status":
                        active = user_scanners.get(chat_id, False)
                        status = f"""📊 <b>Статус сканера</b>

🟢 Уведомления: {'Включены ✅' if active else 'Выключены ⏹️'}
📈 Монет: {len(SYMBOLS)}
🏦 Бирж: {len(EXCHANGES)}
💰 MIN PROFIT: {MIN_PROFIT}%"""
                        
                        tg_requests.post(
                            f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
                            json={"chat_id": chat_id, "text": status, "parse_mode": "HTML"}
                        )
                    
                    elif text == "/on":
                        user_scanners[chat_id] = True
                        tg_requests.post(
                            f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
                            json={"chat_id": chat_id, "text": "✅ Уведомления включены! Я буду присылать спреды."}
                        )
                    
                    elif text == "/off":
                        user_scanners[chat_id] = False
                        tg_requests.post(
                            f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
                            json={"chat_id": chat_id, "text": "⏹️ Уведомления выключены!"}
                        )
                
                # Обработка callback кнопок (если есть)
                callback = update.get("callback_query")
                if callback:
                    chat_id = callback["message"]["chat"]["id"]
                    data = callback["data"]
                    
                    if data == "start":
                        user_scanners[chat_id] = True
                    elif data == "stop":
                        user_scanners[chat_id] = False
                    
                    tg_requests.post(
                        f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/answerCallbackQuery",
                        json={"callback_query_id": callback["id"]}
                    )
            
        except Exception as e:
            logger.debug(f"Telegram error: {e}")
        
        tg_time.sleep(1)

# ========== WEB-СЕРВЕР ДЛЯ RENDER ==========
app = Flask(__name__)

@app.route('/')
def home():
    return "✅ Арбитражный сканер работает! Управляйте через Telegram бота."

@app.route('/health')
def health():
    return "OK"

def run_web():
    app.run(host='0.0.0.0', port=8080, debug=False)

# ========== ОСНОВНОЙ СКАНЕР ==========
async def main_scanner():
    logger.info("🚀 Сканер запущен!")
    logger.info(f"🏦 Активных бирж: {len(EXCHANGES)}")
    logger.info(f"📊 Монет: {len(SYMBOLS)}")
    logger.info(f"🎯 MIN_PROFIT: {MIN_PROFIT}%")
    logger.info(f"📈 Минимальный объем: ${MIN_VOLUME_24H:,.0f}")
    logger.info("=" * 60)
    
    last_alerts = {}
    
    while True:
        try:
            start = time.time()
            
            # Получаем цены
            prices = await get_all_prices()
            
            # Ищем возможности
            opps = find_opportunities(prices)
            
            if opps:
                logger.info(f"🎯 Найдено {len(opps)} спредов!")
                
                for opp in opps[:10]:  # Топ-10
                    key = f"{opp['symbol']}_{opp['buy_exchange']}_{opp['sell_exchange']}"
                    now = time.time()
                    
                    # Не спамим одинаковыми спредами чаще 5 минут
                    if key not in last_alerts or (now - last_alerts.get(key, 0)) > 300:
                        last_alerts[key] = now
                        await send_alert_to_all(opp)
                        logger.info(f"📨 Уведомление отправлено: {opp['symbol']} ({opp['buy_exchange']} → {opp['sell_exchange']})")
            else:
                logger.info("😴 Спредов выше порога нет...")
            
            elapsed = time.time() - start
            logger.info(f"⚡ Сканирование завершено за {elapsed:.1f} сек")
            
            await asyncio.sleep(SCAN_INTERVAL)
            
        except Exception as e:
            logger.error(f"❌ Ошибка: {e}")
            await asyncio.sleep(60)

# ========== АВТОПИНГ ==========
def keep_alive():
    """Каждые 10 минут пингует сервер"""
    url = "http://localhost:8080/"
    while True:
        try:
            requests.get(url, timeout=5)
            print("🔄 Автопинг: сервер активен")
        except:
            print("⚠️ Автопинг: ошибка")
        time.sleep(600)

# ========== ЗАПУСК ==========
async def main():
    logger.info("=" * 60)
    logger.info("🚀 АРБИТРАЖНЫЙ СКАНЕР - ПРОДУКТИВНАЯ ВЕРСИЯ")
    logger.info("=" * 60)
    logger.info(f"📊 Монет: {len(SYMBOLS)}")
    logger.info(f"Первые 10 монет: {SYMBOLS[:10]}")
    logger.info(f"🏦 Бирж: {len(EXCHANGES)}")
    logger.info(f"🎯 MIN_PROFIT: {MIN_PROFIT}%")
    logger.info(f"📈 Мин. объем: ${MIN_VOLUME_24H:,.0f}")
    logger.info("=" * 60)
    
    # Запускаем веб-сервер
    threading.Thread(target=run_web, daemon=True).start()
    
    # Запускаем автопинг
    threading.Thread(target=keep_alive, daemon=True).start()
    
    # Запускаем Telegram бота
    threading.Thread(target=run_telegram_bot, daemon=True).start()
    
    # Запускаем сканер
    await main_scanner()

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        logger.info("🛑 Остановка")
