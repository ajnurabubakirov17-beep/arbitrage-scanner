    text = f"{warning}🤖 <b>АРБИТРАЖНЫЙ СКАНЕР</b>\n\n📊 Монет: <b>{len(TOP_COINS)}</b>\n🏦 Бирж: <b>{len(EXCHANGES)}</b>\n\n⚙️ <b>НАСТРОЙКИ:</b>\n💰 Сумма: <b>${user.get('amount', 100)}</b>\n🎯 Min спред: <b>{user.get('min_spread', 0.3)}%</b>\n⭐ Избранное: {', '.join(favorites[:5]) if favorites else 'нет'}\n\n💎 <b>ПОДПИСКА:</b>\n{sub_status}\n\n👇 ВЫБЕРИТЕ ДЕЙСТВИЕ:"
    send_message(chat_id, text, json.dumps(keyboard))

def show_favorites_menu(chat_id):
    favorites = get_user_favorites(chat_id)
    top_coins = TOP_COINS[:30] if TOP_COINS else ["BTC", "ETH", "SOL", "BNB", "XRP", "DOGE", "ADA", "AVAX", "DOT", "LINK"]
